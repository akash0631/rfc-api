@{
    ViewBag.Title = "RFC Swagger Preview";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>@ViewBag.Title — V2 Retail</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/5.17.14/swagger-ui.css">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--accent:#2563eb;--green:#16a34a;--bg:#f5f6fa;--white:#fff;--border:#e2e6ef;--text:#1a2035;--sub:#4a5568;--mono:'DM Mono',Consolas,monospace;}
body{background:var(--bg);font-family:'DM Sans',system-ui,sans-serif;color:var(--text);}
header{background:var(--white);border-bottom:1px solid var(--border);padding:0 28px;height:54px;display:flex;align-items:center;gap:12px;}
.logo{width:28px;height:28px;background:var(--accent);border-radius:7px;display:grid;place-items:center;font-weight:700;color:#fff;font-size:12px;}
.logo-name{font-size:14px;font-weight:700;}
.logo-name span{color:var(--accent);}
.hdr-right{margin-left:auto;display:flex;gap:12px;align-items:center;}
.hdr-link{font-size:12px;color:var(--sub);text-decoration:none;padding:5px 10px;border-radius:6px;border:1px solid var(--border);}
.hdr-link:hover{border-color:var(--accent);color:var(--accent);}
.page{max-width:1100px;margin:24px auto;padding:0 16px 60px;}
.page-title{font-size:20px;font-weight:700;margin-bottom:4px;}
.page-sub{font-size:13px;color:var(--sub);margin-bottom:20px;}
/* INFO BAR */
.info-bar{background:var(--white);border:1px solid var(--border);border-radius:10px;padding:14px 18px;display:flex;align-items:center;gap:16px;margin-bottom:20px;flex-wrap:wrap;}
.info-item{display:flex;flex-direction:column;gap:2px;}
.info-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:#8896ab;}
.info-value{font-size:13px;font-weight:600;color:var(--text);font-family:var(--mono);}
.badge-branch{background:#eff6ff;border:1px solid #bfdbfe;color:var(--accent);padding:3px 9px;border-radius:5px;font-size:11px;font-weight:700;font-family:var(--mono);}
.badge-live{background:#f0fdf4;border:1px solid #86efac;color:var(--green);padding:3px 9px;border-radius:5px;font-size:11px;font-weight:700;}
/* TAB BAR */
.tab-bar{display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:0;}
.tab{padding:10px 20px;font-size:13px;font-weight:600;color:#8896ab;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:.15s;}
.tab.active{color:var(--accent);border-color:var(--accent);}
.tab-panel{background:var(--white);border:1px solid var(--border);border-top:none;border-radius:0 0 12px 12px;min-height:400px;}
/* SWAGGER PANEL */
.swagger-wrap{padding:10px;}
.swagger-wrap .swagger-ui .topbar{display:none!important;}
.swagger-wrap .swagger-ui .info .title{font-size:18px!important;}
.swagger-wrap .swagger-ui .opblock.opblock-post{background:#f0fdf4!important;border-color:#86efac!important;}
.swagger-wrap .swagger-ui .opblock.opblock-post .opblock-summary-method{background:var(--green)!important;}
/* JSON TAB */
.json-panel{padding:20px;}
.json-box{background:#f8f9fc;border:1px solid var(--border);border-radius:8px;padding:16px;font-family:var(--mono);font-size:12px;line-height:1.7;white-space:pre;overflow:auto;max-height:600px;color:var(--sub);}
.json-box::-webkit-scrollbar{width:4px;} .json-box::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
/* TRY IT */
.try-panel{padding:20px;}
.field{margin-bottom:14px;}
.field label{display:block;font-size:11px;font-weight:700;color:var(--sub);text-transform:uppercase;letter-spacing:.7px;margin-bottom:5px;}
.field input,.field textarea{width:100%;background:#f8f9fc;border:1.5px solid var(--border);border-radius:7px;padding:9px 12px;font-size:13px;font-family:var(--mono);outline:none;transition:.15s;}
.field input:focus,.field textarea:focus{border-color:var(--accent);background:var(--white);}
.btn{padding:9px 20px;border-radius:7px;font-size:13px;font-weight:600;cursor:pointer;border:none;font-family:inherit;display:inline-flex;align-items:center;gap:6px;}
.btn-primary{background:var(--accent);color:#fff;}
.btn-primary:hover{background:#1d4ed8;}
.resp-box{margin-top:16px;background:#f8f9fc;border:1px solid var(--border);border-radius:8px;padding:14px;font-family:var(--mono);font-size:12px;white-space:pre;overflow:auto;max-height:300px;display:none;}
.resp-ok{border-color:#86efac;background:#f0fdf4;color:var(--green);}
.resp-err{border-color:#fca5a5;background:#fef2f2;color:#dc2626;}
.spin{display:inline-block;width:12px;height:12px;border:2px solid currentColor;border-top-color:transparent;border-radius:50%;animation:rot .65s linear infinite;}
@@keyframes rot{to{transform:rotate(360deg)}}
</style>
</head>
<body>
<header>
  <div class="logo">V2</div>
  <span class="logo-name">Retail <span>RFC</span> Swagger</span>
  <div class="hdr-right">
    <a class="hdr-link" href="/RfcDocUpload">⬆ Upload</a>
    <a class="hdr-link" href="/RfcDeploy/SwaggerUI">📖 Full Swagger</a>
    <a class="hdr-link" href="/RfcDeploy/Explorer">🔍 Explorer</a>
  </div>
</header>

<div class="page">
  <div class="page-title" id="pageTitle">RFC Swagger Preview</div>
  <div class="page-sub">Live Swagger UI for the generated RFC endpoint. Generated from your uploaded document and auto-updated on every push.</div>

  <!-- INFO BAR -->
  <div class="info-bar">
    <div class="info-item">
      <span class="info-label">Branch</span>
      <span class="badge-branch">NIKHIL</span>
    </div>
    <div class="info-item">
      <span class="info-label">RFC Name</span>
      <span class="info-value" id="rfcNameDisplay">—</span>
    </div>
    <div class="info-item">
      <span class="info-label">Endpoint</span>
      <span class="info-value" id="endpointDisplay">—</span>
    </div>
    <div class="info-item">
      <span class="info-label">Status</span>
      <span class="badge-live" id="statusBadge">● Generated</span>
    </div>
    <div style="margin-left:auto">
      <a id="ghFileLink" href="#" target="_blank" class="hdr-link" style="font-size:11px;">View on GitHub →</a>
    </div>
  </div>

  <!-- TAB BAR -->
  <div class="tab-bar">
    <div class="tab active" onclick="showTab('swagger')">📖 Swagger UI</div>
    <div class="tab" onclick="showTab('json')">{ } OpenAPI JSON</div>
    <div class="tab" onclick="showTab('try')">▶ Try It</div>
  </div>

  <!-- SWAGGER TAB -->
  <div class="tab-panel" id="tab-swagger">
    <div class="swagger-wrap" id="swagger-ui-wrap"></div>
  </div>

  <!-- JSON TAB -->
  <div class="tab-panel" id="tab-json" style="display:none">
    <div class="json-panel">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
        <span style="font-size:13px;font-weight:600;color:var(--sub)">OpenAPI 3.0 Specification</span>
        <button class="btn btn-primary" style="padding:6px 14px;font-size:12px;" onclick="copyJson()">📋 Copy JSON</button>
      </div>
      <div class="json-box" id="jsonBox">Loading...</div>
    </div>
  </div>

  <!-- TRY IT TAB -->
  <div class="tab-panel" id="tab-try" style="display:none">
    <div class="try-panel">
      <div class="field">
        <label>IIS Endpoint</label>
        <input type="text" id="tryEndpoint" value="http://v2retail.net:9005/api/" readonly style="color:var(--accent)">
      </div>
      <div class="field">
        <label>Request Body (JSON)</label>
        <textarea id="tryBody" rows="8">{"IM_DATA": [{"EBELN": "4500001234","PO_ITEM": "00001","MATNR": "MAT001","DELIV_DATE": "20260401"}]}</textarea>
      </div>
      <button class="btn btn-primary" onclick="tryIt()"><span id="trySpinner" style="display:none" class="spin"></span> ▶ Send Request</button>
      <div class="resp-box" id="tryResp"></div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/5.17.14/swagger-ui-bundle.js"></script>
<script>
var openApiSpec = null;

// Parse query params
var params = new URLSearchParams(window.location.search);
var rfcName = params.get('rfcName') || '@(ViewBag.RfcName ?? "RFC_NAME")';
var folder  = params.get('folder')  || '@(ViewBag.Folder ?? "Finance")';
var desc    = params.get('desc')    || '@(ViewBag.Desc ?? "SAP RFC Endpoint")';
var swaggerJsonUrl = '@Html.Raw(ViewBag.OpenApiUrl ?? "/RfcDocUpload/SwaggerJson")';

// Add query params to swagger URL if present
if (rfcName && rfcName !== 'RFC_NAME') {
    swaggerJsonUrl += (swaggerJsonUrl.includes('?') ? '&' : '?') + 'rfcName=' + encodeURIComponent(rfcName) + '&folder=' + encodeURIComponent(folder) + '&desc=' + encodeURIComponent(desc);
}

// Update info bar
document.getElementById('rfcNameDisplay').textContent  = rfcName;
document.getElementById('endpointDisplay').textContent = '/api/' + rfcName;
document.getElementById('pageTitle').textContent       = rfcName + ' — Swagger Preview';
document.getElementById('tryEndpoint').value           = 'http://v2retail.net:9005/api/' + rfcName;
document.getElementById('ghFileLink').href             = 'https://github.com/akash0631/rfc-api/tree/NIKHIL/Controllers/' + folder + '/' + rfcName + 'Controller.cs';

// Load Swagger UI
SwaggerUIBundle({
    url:          swaggerJsonUrl,
    dom_id:       '#swagger-ui-wrap',
    presets:      [SwaggerUIBundle.presets.apis, SwaggerUIBundle.SwaggerUIStandalonePreset],
    layout:       'BaseLayout',
    deepLinking:  true,
    tryItOutEnabled: true,
    onComplete: function(swaggerApi) {
        openApiSpec = swaggerApi;
        document.getElementById('statusBadge').textContent = '● Live';
        document.getElementById('statusBadge').style.background = '#f0fdf4';
        // Load JSON tab
        fetch(swaggerJsonUrl).then(r => r.json()).then(d => {
            document.getElementById('jsonBox').textContent = JSON.stringify(d, null, 2);
        }).catch(() => { document.getElementById('jsonBox').textContent = 'Could not load JSON spec.'; });
    }
});

function showTab(name) {
    ['swagger','json','try'].forEach(function(t) {
        document.getElementById('tab-' + t).style.display = t === name ? 'block' : 'none';
    });
    document.querySelectorAll('.tab').forEach(function(el, i) {
        el.classList.toggle('active', ['swagger','json','try'][i] === name);
    });
}

function copyJson() {
    var text = document.getElementById('jsonBox').textContent;
    navigator.clipboard.writeText(text).then(function() {
        var btn = event.target; btn.textContent = '✓ Copied!'; setTimeout(function() { btn.textContent = '📋 Copy JSON'; }, 2000);
    });
}

async function tryIt() {
    var endpoint = document.getElementById('tryEndpoint').value.trim();
    var body     = document.getElementById('tryBody').value.trim();
    var resp     = document.getElementById('tryResp');
    var spin     = document.getElementById('trySpinner');
    spin.style.display = 'inline-block';
    resp.style.display = 'none';
    try {
        var r = await fetch(endpoint, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body });
        var d = await r.json();
        resp.textContent = JSON.stringify(d, null, 2);
        resp.className   = 'resp-box ' + (r.ok ? 'resp-ok' : 'resp-err');
        resp.style.display = 'block';
    } catch(e) {
        resp.textContent   = 'Error: ' + e.message + '

(IIS server may not be reachable from browser)';
        resp.className     = 'resp-box resp-err';
        resp.style.display = 'block';
    }
    spin.style.display = 'none';
}
</script>
</body>
</html>
