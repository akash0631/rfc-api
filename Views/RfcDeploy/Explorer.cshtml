@model IEnumerable<Vendor_SRM_Routing_Application.Controllers.RfcEndpoint>
@{
    ViewBag.Title = "V2 Retail - RFC API Explorer";
    Layout = null;
    var groups = Model.GroupBy(e => e.Group).ToList();
    string iisBase = ViewBag.IISBase as string ?? "http://v2retail.net:9005";
    string dabBase = ViewBag.DABBase as string ?? "https://my-dab-app.azurewebsites.net";
    string ghBase  = ViewBag.GHBase  as string ?? "https://github.com/akash0631/rfc-api/blob/master/";
    int total      = ViewBag.TotalCount != null ? (int)ViewBag.TotalCount : 0;
    int groupCount = ViewBag.GroupCount != null ? (int)ViewBag.GroupCount : 0;
    int paramCount = ViewBag.ParamCount != null ? (int)ViewBag.ParamCount : 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>@ViewBag.Title</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@@400;500;600&family=Inter:wght@@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f0f2f7;--white:#fff;--surface:#f7f8fc;--border:#e0e4ef;--border2:#c8d0e3;
  --text:#111827;--sub:#374151;--muted:#6b7280;--dim:#9ca3af;
  --accent:#2563eb;--al:#eff6ff;--ab:#bfdbfe;
  --green:#15803d;--gl:#f0fdf4;--gb:#86efac;
  --amber:#92400e;--aml:#fffbeb;--ambb:#fde68a;
  --red:#dc2626;--rl:#fef2f2;--rb:#fca5a5;
  --orange:#c2410c;--ol:#fff7ed;--ob:#fed7aa;
  --purple:#6d28d9;--pl:#f5f3ff;--pb:#ddd6fe;
  --sans:'Inter',system-ui,sans-serif;
  --mono:'IBM Plex Mono',Consolas,monospace;
}
body{background:var(--bg);font-family:var(--sans);color:var(--text);min-height:100vh;display:flex;flex-direction:column;}
.topbar{background:var(--white);border-bottom:1.5px solid var(--border);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;box-shadow:0 1px 4px rgba(0,0,0,.06);}
.logo{display:flex;align-items:center;gap:10px;}
.logo-mark{width:30px;height:30px;background:var(--accent);border-radius:7px;display:grid;place-items:center;font-weight:800;color:#fff;font-size:13px;font-family:var(--mono);}
.logo-name{font-size:14px;font-weight:700;letter-spacing:-.3px;}.logo-name span{color:var(--accent);}
.topbar-nav{display:flex;align-items:center;gap:4px;}
.topbar-nav a{font-size:12px;font-weight:500;color:var(--muted);text-decoration:none;padding:5px 10px;border-radius:6px;transition:.15s;}
.topbar-nav a:hover,.topbar-nav a.active{color:var(--accent);background:var(--al);}
.topbar-nav a.active{font-weight:600;}
.topbar-stats{display:flex;gap:16px;font-size:12px;color:var(--muted);}
.topbar-stats strong{color:var(--text);font-weight:700;}
.layout{display:flex;flex:1;overflow:hidden;height:calc(100vh - 56px);}
.sidebar{width:248px;flex-shrink:0;background:var(--white);border-right:1.5px solid var(--border);display:flex;flex-direction:column;overflow:hidden;}
.search-wrap{padding:11px 12px;border-bottom:1px solid var(--border);position:relative;}
.search-icon{position:absolute;left:22px;top:50%;transform:translateY(-50%);font-size:13px;pointer-events:none;}
.search{width:100%;background:var(--surface);border:1.5px solid var(--border);border-radius:7px;padding:7px 10px 7px 32px;font-size:12.5px;outline:none;transition:.15s;}
.search:focus{border-color:var(--accent);background:var(--white);}
.sidebar-body{overflow-y:auto;flex:1;}
.sidebar-body::-webkit-scrollbar{width:3px;}
.sidebar-body::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.group-hdr{padding:8px 14px 3px;font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--dim);display:flex;align-items:center;justify-content:space-between;margin-top:6px;}
.group-badge{background:var(--surface);border:1px solid var(--border);padding:0 6px;border-radius:8px;font-size:9px;color:var(--dim);}
.ep-item{padding:6px 14px 6px 18px;font-size:12px;color:var(--sub);cursor:pointer;border-left:2px solid transparent;transition:.12s;display:flex;align-items:center;gap:7px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.ep-item:hover{color:var(--text);background:var(--surface);}
.ep-item.active{color:var(--accent);border-left-color:var(--accent);background:var(--al);font-weight:600;}
.ep-dot{width:5px;height:5px;border-radius:50%;background:var(--green);flex-shrink:0;}
.ep-item.active .ep-dot{background:var(--accent);}
.main{flex:1;overflow-y:auto;padding:28px 32px 60px;}
.main::-webkit-scrollbar{width:5px;}
.main::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}
.welcome{max-width:600px;margin:60px auto;text-align:center;}
.welcome-icon{font-size:48px;margin-bottom:16px;}
.welcome h2{font-size:22px;font-weight:700;margin-bottom:8px;}
.welcome p{color:var(--muted);font-size:13.5px;line-height:1.7;}
.stats-row{display:flex;gap:14px;justify-content:center;margin-top:28px;flex-wrap:wrap;}
.stat{background:var(--white);border:1.5px solid var(--border);border-radius:10px;padding:14px 22px;min-width:110px;text-align:center;}
.stat .n{font-size:26px;font-weight:800;color:var(--accent);font-family:var(--mono);}
.stat .l{font-size:11px;color:var(--muted);margin-top:2px;}
.quick-links{display:flex;gap:8px;justify-content:center;margin-top:20px;flex-wrap:wrap;}
.ql{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:12px;font-weight:600;text-decoration:none;transition:.15s;}
.ql-blue{background:var(--al);border:1px solid var(--ab);color:var(--accent);}
.ql-green{background:var(--gl);border:1px solid var(--gb);color:var(--green);}
.ql-purple{background:var(--pl);border:1px solid var(--pb);color:var(--purple);}
.ql:hover{filter:brightness(.95);}
.ep-header{margin-bottom:22px;}
.ep-title-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:8px;}
.method-pill{font-family:var(--mono);font-size:11px;font-weight:600;padding:4px 12px;border-radius:6px;background:var(--gl);color:var(--green);border:1.5px solid var(--gb);}
.ep-name{font-size:22px;font-weight:800;letter-spacing:-.4px;font-family:var(--mono);}
.env-pill{font-size:10px;font-weight:700;padding:3px 10px;border-radius:5px;background:var(--al);border:1px solid var(--ab);color:var(--accent);font-family:var(--mono);}
.ep-rfc-line{font-size:12px;color:var(--muted);margin-bottom:10px;}
.ep-rfc-line code{background:var(--surface);border:1px solid var(--border);padding:1px 7px;border-radius:4px;font-family:var(--mono);color:var(--sub);font-size:11.5px;}
.ep-desc{font-size:14px;color:var(--sub);line-height:1.7;margin-bottom:14px;}
.route-box{display:inline-flex;align-items:center;gap:6px;background:var(--aml);border:1.5px solid var(--ambb);border-radius:8px;padding:8px 14px;font-family:var(--mono);font-size:12px;margin-bottom:14px;}
.route-base{color:var(--muted);}
.route-path{color:var(--amber);font-weight:600;}
.gh-link{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;color:var(--muted);text-decoration:none;margin-top:6px;}
.gh-link:hover{color:var(--accent);}
.card{background:var(--white);border:1.5px solid var(--border);border-radius:10px;margin-bottom:14px;overflow:hidden;}
.card-hdr{padding:10px 16px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.card-title{font-size:9.5px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:8px;}
.c-badge{background:var(--white);border:1px solid var(--border);padding:0 7px;border-radius:8px;font-size:9.5px;color:var(--dim);}
.try-btn{font-size:11px;font-weight:600;padding:4px 12px;border-radius:6px;background:var(--accent);color:#fff;border:none;cursor:pointer;transition:.15s;}
.try-btn:hover{background:#1d4ed8;}
.param-tbl{width:100%;border-collapse:collapse;}
.param-tbl th{padding:8px 16px;font-size:9.5px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted);text-align:left;border-bottom:1px solid var(--border);background:var(--surface);}
.param-tbl td{padding:9px 16px;font-size:12.5px;border-bottom:1px solid var(--border);color:var(--sub);vertical-align:middle;}
.param-tbl tr:last-child td{border-bottom:none;}
.param-tbl tr:hover td{background:#fafbff;}
.pname{color:var(--accent);font-family:var(--mono);font-weight:500;}
.ptype{color:var(--muted);font-family:var(--mono);font-size:11px;background:var(--surface);border:1px solid var(--border);padding:1px 6px;border-radius:4px;}
.preq{font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px;font-family:var(--mono);}
.preq.req{background:var(--gl);color:var(--green);border:1px solid var(--gb);}
.preq.opt{background:var(--surface);color:var(--muted);border:1px solid var(--border);}
.ptable{font-size:9.5px;font-weight:700;padding:2px 7px;border-radius:4px;background:var(--pl);color:var(--purple);border:1px solid var(--pb);font-family:var(--mono);}
.chips{padding:12px 16px;display:flex;flex-wrap:wrap;gap:8px;}
.chip{font-family:var(--mono);font-size:11px;background:var(--ol);border:1px solid var(--ob);color:var(--orange);padding:4px 10px;border-radius:5px;}
.try-panel{padding:16px;}
.try-fields{display:flex;flex-direction:column;gap:10px;margin-bottom:14px;}
.try-field label{font-size:10.5px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:4px;}
.try-field input,.try-field textarea{width:100%;background:var(--surface);border:1.5px solid var(--border);border-radius:7px;padding:8px 11px;font-size:12.5px;font-family:var(--mono);color:var(--text);outline:none;transition:.15s;}
.try-field input:focus,.try-field textarea:focus{border-color:var(--accent);background:var(--white);}
.try-field textarea{resize:vertical;min-height:70px;}
.send-btn{background:var(--accent);color:#fff;border:none;border-radius:7px;padding:10px 20px;font-size:13px;font-weight:600;cursor:pointer;transition:.15s;}
.send-btn:hover{background:#1d4ed8;}.send-btn:disabled{opacity:.4;cursor:not-allowed;}
.response-box{margin-top:14px;background:#13141f;border-radius:8px;overflow:hidden;}
.response-hdr{padding:8px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid rgba(255,255,255,.08);}
.resp-status{font-size:11px;font-weight:600;font-family:var(--mono);padding:2px 8px;border-radius:4px;}
.resp-200{background:#166534;color:#86efac;}.resp-400{background:#7f1d1d;color:#fca5a5;}
.resp-time{font-size:11px;color:#64748b;margin-left:auto;}
.resp-body{padding:14px;font-family:var(--mono);font-size:11px;color:#9aa5d4;max-height:260px;overflow-y:auto;white-space:pre-wrap;word-break:break-all;}
.datalake-box{padding:12px 16px;display:flex;align-items:center;gap:10px;border-top:1px solid var(--border);}
.dl-label{font-size:10px;color:var(--muted);font-weight:600;letter-spacing:.8px;text-transform:uppercase;margin-bottom:2px;}
.dl-url{font-family:var(--mono);font-size:11.5px;color:var(--accent);text-decoration:none;word-break:break-all;}
.dl-url:hover{text-decoration:underline;}
.example-box{padding:14px 16px;}
.example-pre{background:#13141f;color:#9aa5d4;border-radius:8px;padding:14px;font-family:var(--mono);font-size:11px;overflow-x:auto;white-space:pre;line-height:1.65;}
.copy-btn{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:#9aa5d4;border-radius:6px;padding:4px 12px;font-size:10.5px;cursor:pointer;font-family:var(--mono);transition:.15s;}
.copy-btn:hover{background:rgba(255,255,255,.15);}
</style>
</head>
<body>

<div class="topbar">
  <div class="logo">
    <div class="logo-mark">V2</div>
    <div class="logo-name">Retail <span>RFC</span> API Explorer</div>
  </div>
  <div class="topbar-nav">
    <a href="/RfcDeploy">⚡ Deploy</a>
    <a href="/RfcDeploy/Explorer" class="active">🔍 Explorer</a>
    <a href="/RfcDeploy/SwaggerUI">📖 Swagger UI</a>
    <a href="/RfcDeploy/OpenApiJson" target="_blank">📄 OpenAPI JSON</a>
    <a href="/swagger/ui/index">🔧 Swashbuckle</a>
  </div>
  <div class="topbar-stats">
    <span><strong>@total</strong> endpoints</span>
    <span><strong>@groupCount</strong> modules</span>
    <span><strong>@paramCount</strong> params</span>
  </div>
</div>

<div class="layout">
  <nav class="sidebar">
    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input class="search" id="srch" placeholder="Search RFCs, params…" oninput="doSearch(this.value)">
    </div>
    <div class="sidebar-body">
      @foreach (var g in groups)
      {
        <div class="group-hdr"><span>@g.Key</span><span class="group-badge">@g.Count()</span></div>
        foreach (var ep in g)
        {
          <div class="ep-item" id="si_@ep.Name" onclick="showEndpoint('@ep.Name')">
            <span class="ep-dot"></span>@ep.Name
          </div>
        }
      }
    </div>
  </nav>

  <div class="main">
    <div id="welcome">
      <div class="welcome">
        <div class="welcome-icon">⚙️</div>
        <h2>V2 Retail · SAP RFC API</h2>
        <p>All SAP RFC REST endpoints deployed on IIS (V2DC-ADDVERB · 192.168.151.24).<br>Select an endpoint from the sidebar to view params, schema and try it live.</p>
        <div class="stats-row">
          <div class="stat"><div class="n">@total</div><div class="l">Total RFCs</div></div>
          <div class="stat"><div class="n">@groupCount</div><div class="l">Modules</div></div>
          <div class="stat"><div class="n">@paramCount</div><div class="l">Parameters</div></div>
        </div>
        <div class="quick-links">
          <a class="ql ql-blue"   href="/RfcDeploy/SwaggerUI">📖 Swagger UI</a>
          <a class="ql ql-green"  href="/RfcDeploy/OpenApiJson" target="_blank">📄 OpenAPI 3.0</a>
          <a class="ql ql-purple" href="/RfcDeploy/Manifest"    target="_blank">📦 Manifest JSON</a>
          <a class="ql ql-blue"   href="/RfcDeploy">⚡ Deploy RFC</a>
        </div>
      </div>
    </div>
    <div id="detail" style="display:none"></div>
  </div>
</div>

<script>
var ENDPOINTS = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model));
var IIS_BASE  = '@Html.Raw(iisBase)';
var GH_BASE   = '@Html.Raw(ghBase)';
var current   = null;

function showEndpoint(name) {
  var ep = ENDPOINTS.find(function(e){ return e.Name === name; });
  if (!ep) return;
  current = ep;
  location.hash = name;
  document.querySelectorAll('.ep-item').forEach(function(el){ el.classList.remove('active'); });
  var si = document.getElementById('si_' + name);
  if (si) { si.classList.add('active'); si.scrollIntoView({block:'nearest'}); }
  document.getElementById('welcome').style.display = 'none';
  document.getElementById('detail').style.display  = 'block';
  renderDetail(ep);
}

function renderDetail(ep) {
  // Params table
  var paramsHtml = '';
  if (ep.Parameters && ep.Parameters.length > 0) {
    paramsHtml = '<table class="param-tbl"><thead><tr><th>Parameter</th><th>SAP Type</th><th>Required</th><th>Description</th></tr></thead><tbody>';
    ep.Parameters.forEach(function(p) {
      var typeHtml = p.IsTable
        ? '<span class="ptable">TABLE</span> <span class="ptype">' + (p.SapType||'') + '</span>'
        : '<span class="ptype">' + (p.SapType||'string') + '</span>';
      paramsHtml += '<tr>'
        + '<td class="pname">' + p.Name + '</td>'
        + '<td>' + typeHtml + '</td>'
        + '<td><span class="preq ' + (p.Required?'req':'opt') + '">' + (p.Required?'required':'optional') + '</span></td>'
        + '<td>' + (p.Description||'–') + '</td></tr>';
    });
    paramsHtml += '</tbody></table>';
  } else {
    paramsHtml = '<div style="padding:16px;font-size:13px;color:var(--muted)">No parameters extracted — view source file for full spec.</div>';
  }

  // Response chips
  var tablesHtml = (ep.ResponseTables||[]).map(function(t){
    return '<span class="chip">' + t + '</span>';
  }).join('') || '<span style="padding:4px;font-size:12px;color:var(--muted)">None detected</span>';

  // Build example body
  var exBody = {};
  (ep.Parameters||[]).forEach(function(p) {
    if (p.IsTable) { exBody[p.Name] = [{'_note':'array of rows — see description'}]; return; }
    var ex = {DATS:'20260101',BUDAT:'20260101',BUKRS:'1000',EBELN:'4500001234',
              MATNR:'ABC001',LIFNR:'V001',WERKS_D:'DC01',WWWOBJID:'USER01',
              UNAME:'USER01',MENGE:'100',CHAR10:'DL01',LGPLA:'DC01-01-01',
              ZEXT_HU:'HU0001234',ZZPALETTE:'PAL001',ZVEH:'DL01TRUCK'}[p.SapType]
             || '[' + (p.SapType||'string') + ']';
    exBody[p.Name] = ex;
  });
  var exJson  = JSON.stringify(exBody, null, 2);
  var curlCmd = 'curl -X POST "' + IIS_BASE + '/' + ep.Route + '" \\\n'
              + '  -H "Content-Type: application/json" \\\n'
              + '  -d \'' + JSON.stringify(exBody) + "'";

  // Data lake
  var datalakeHtml = '';
  if (ep.DataLakeEndpoint) {
    datalakeHtml = '<div class="datalake-box"><span style="font-size:16px">📡</span>'
      + '<div><div class="dl-label">Data Lake (Azure DAB · OData)</div>'
      + '<a class="dl-url" href="' + ep.DataLakeEndpoint + '?$top=100" target="_blank">'
      + ep.DataLakeEndpoint + '?$top=100&$filter=...</a></div></div>';
  }

  // Try it fields
  var tryFields = (ep.Parameters||[]).map(function(p) {
    if (p.IsTable) return '<div class="try-field"><label>' + p.Name
      + ' <span style="font-size:9px;color:var(--purple);font-family:var(--mono)">TABLE</span></label>'
      + '<textarea id="tf_' + p.Name + '" placeholder=\'[{"FIELD":"VALUE"}]\'></textarea></div>';
    return '<div class="try-field"><label>' + p.Name
      + ' <span style="font-size:9px;color:var(--muted)">' + (p.SapType||'') + '</span></label>'
      + '<input id="tf_' + p.Name + '" placeholder="' + esc(p.Description||p.Name) + '"></div>';
  }).join('');

  document.getElementById('detail').innerHTML =
    '<div class="ep-header">'
    + '<div class="ep-title-row">'
    + '<span class="method-pill">POST</span>'
    + '<span class="ep-name">' + ep.Name + '</span>'
    + '<span class="env-pill">' + (ep.Environment||'Dev') + ' · ' + (ep.SapHost||'192.168.144.174') + '</span>'
    + '</div>'
    + '<div class="ep-rfc-line">SAP RFC: <code>' + ep.SapRfc + '</code>&nbsp;·&nbsp;Module: <code>' + ep.Group + '</code></div>'
    + '<div class="ep-desc">' + esc(ep.Description||'') + '</div>'
    + '<div class="route-box"><span class="route-base">' + IIS_BASE + '/</span><span class="route-path">' + ep.Route + '</span></div>'
    + (ep.FilePath ? '<br><a class="gh-link" href="' + GH_BASE + ep.FilePath + '" target="_blank">&#8599; View source on GitHub</a>' : '')
    + '</div>'

    + '<div class="card">'
    + '<div class="card-hdr"><span class="card-title">Request Parameters <span class="c-badge">' + (ep.Parameters||[]).length + '</span></span>'
    + '<button class="try-btn" onclick="toggleTry()">&#9889; Try it out</button></div>'
    + paramsHtml + '</div>'

    + '<div class="card" id="tryCard" style="display:none">'
    + '<div class="card-hdr"><span class="card-title">Try it out — Live</span></div>'
    + '<div class="try-panel">'
    + '<div class="try-fields">' + tryFields + '</div>'
    + '<button class="send-btn" id="sendBtn" onclick="sendReq()">&#9654; Send Request</button>'
    + '<div id="respBox" style="display:none" class="response-box">'
    + '<div class="response-hdr"><span class="resp-status" id="rStatus">200</span><span class="resp-time" id="rTime"></span></div>'
    + '<div class="resp-body" id="rBody"></div></div>'
    + '</div></div>'

    + '<div class="card">'
    + '<div class="card-hdr"><span class="card-title">SAP Response Tables <span class="c-badge">' + (ep.ResponseTables||[]).length + '</span></span></div>'
    + '<div class="chips">' + tablesHtml + '</div>'
    + datalakeHtml + '</div>'

    + '<div class="card">'
    + '<div class="card-hdr"><span class="card-title">Example Request</span>'
    + '<button class="copy-btn" onclick="copyCurl()">&#128203; Copy cURL</button></div>'
    + '<div class="example-box">'
    + '<pre class="example-pre" id="curlPre">' + esc(curlCmd) + '</pre>'
    + '<div style="margin-top:10px;font-size:10.5px;color:var(--muted);font-family:var(--mono)">JSON Body:</div>'
    + '<pre class="example-pre" style="margin-top:6px">' + esc(exJson) + '</pre>'
    + '</div></div>';
}

function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function toggleTry(){
  var c = document.getElementById('tryCard');
  c.style.display = c.style.display === 'none' ? 'block' : 'none';
}

async function sendReq(){
  if (!current) return;
  var btn = document.getElementById('sendBtn');
  btn.disabled = true; btn.textContent = 'Sending...';
  var body = {};
  (current.Parameters||[]).forEach(function(p){
    var el = document.getElementById('tf_' + p.Name);
    if (!el) return;
    if (p.IsTable){ try{ body[p.Name]=JSON.parse(el.value||'[]'); }catch(e){ body[p.Name]=[]; } }
    else body[p.Name] = el.value.trim();
  });
  var t0 = Date.now();
  try{
    var r    = await fetch('/' + current.Route, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    var txt  = await r.text();
    var dt   = Date.now() - t0;
    var rs   = document.getElementById('rStatus');
    rs.textContent = r.status + ' ' + r.statusText;
    rs.className   = 'resp-status ' + (r.ok ? 'resp-200' : 'resp-400');
    document.getElementById('rTime').textContent = dt + 'ms';
    try{ document.getElementById('rBody').textContent = JSON.stringify(JSON.parse(txt), null, 2); }
    catch(e){ document.getElementById('rBody').textContent = txt; }
    document.getElementById('respBox').style.display = 'block';
  }catch(e){
    document.getElementById('rBody').textContent = 'Network error: ' + e.message;
    document.getElementById('respBox').style.display = 'block';
  }
  btn.disabled = false; btn.textContent = '\u25B6 Send Request';
}

function copyCurl(){
  var el = document.getElementById('curlPre');
  if(el) navigator.clipboard.writeText(el.textContent).then(function(){
    var b = document.querySelector('.copy-btn'); b.textContent = '\u2713 Copied!';
    setTimeout(function(){ b.textContent = '\u{1F4CB} Copy cURL'; }, 2000);
  });
}

function doSearch(q){
  q = q.toLowerCase().trim();
  document.querySelectorAll('.ep-item').forEach(function(el){
    el.style.display = (!q || el.textContent.toLowerCase().includes(q)) ? '' : 'none';
  });
}

window.addEventListener('load', function(){
  if(location.hash){ var n = decodeURIComponent(location.hash.slice(1));
    var ep = ENDPOINTS.find(function(e){ return e.Name===n; });
    if(ep) showEndpoint(ep.Name); }
});
</script>
</body>
</html>
