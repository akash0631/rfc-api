@{
    ViewBag.Title = "V2 Retail · RFC Portal";
    Layout = null;
    string workerBase = ViewBag.WorkerBase as string ?? "https://v2-rfc-pipeline.akash-bab.workers.dev";
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>@ViewBag.Title</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/5.17.14/swagger-ui.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0d0f14;--surface:#13161e;--surface2:#1a1e28;--surface3:#1f2433;
  --border:#252b3b;--border2:#2e364a;--text:#e8eaf0;--sub:#8b93a8;
  --muted:#545d72;--dim:#363d52;--accent:#3b82f6;--accent-dark:#1d4ed8;
  --ag:rgba(59,130,246,.15);--green:#22c55e;--gb:rgba(34,197,94,.1);
  --gbr:rgba(34,197,94,.25);--amber:#f59e0b;--amb:rgba(245,158,11,.1);
  --red:#ef4444;--rb:rgba(239,68,68,.1);--rbr:rgba(239,68,68,.25);
  --purple:#a855f7;--pb:rgba(168,85,247,.1);
  --sans:'DM Sans',system-ui,sans-serif;
  --mono:'JetBrains Mono',Consolas,monospace;
}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--sans);}
.shell{display:flex;height:100vh;overflow:hidden;}

/* SIDEBAR */
.sidebar{width:60px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;transition:width .25s cubic-bezier(.4,0,.2,1);overflow:hidden;flex-shrink:0;z-index:50;}
.sidebar:hover{width:220px;}
.s-logo{height:56px;display:flex;align-items:center;gap:12px;padding:0 16px;border-bottom:1px solid var(--border);flex-shrink:0;}
.s-logo-icon{width:28px;height:28px;background:var(--accent);border-radius:7px;display:grid;place-items:center;font-weight:700;color:#fff;font-size:12px;font-family:var(--mono);flex-shrink:0;}
.s-logo-text{font-size:13px;font-weight:600;white-space:nowrap;opacity:0;transition:opacity .2s .05s;}
.sidebar:hover .s-logo-text{opacity:1;}
.nav-items{flex:1;padding:10px 0;overflow:hidden;}
.ni{display:flex;align-items:center;gap:13px;padding:10px 16px;cursor:pointer;transition:.15s;border-left:2px solid transparent;white-space:nowrap;}
.ni:hover{background:rgba(59,130,246,.08);color:var(--accent);}
.ni.active{background:rgba(59,130,246,.12);border-left-color:var(--accent);color:var(--accent);}
.ni-icon{font-size:18px;flex-shrink:0;width:28px;text-align:center;}
.ni-label{font-size:13px;font-weight:500;opacity:0;transition:opacity .2s .05s;flex-shrink:0;}
.sidebar:hover .ni-label{opacity:1;}
.s-foot{padding:12px 0;border-top:1px solid var(--border);flex-shrink:0;overflow:hidden;}
.s-stat{padding:8px 16px;display:flex;align-items:center;gap:13px;white-space:nowrap;}
.sdot{width:7px;height:7px;border-radius:50%;background:var(--green);flex-shrink:0;animation:pdot 2.5s infinite;}
@keyframes pdot{0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,.4)}50%{box-shadow:0 0 0 5px rgba(34,197,94,0)}}
.s-stat-lbl{font-size:11px;color:var(--green);font-weight:600;opacity:0;transition:opacity .2s .05s;font-family:var(--mono);}
.sidebar:hover .s-stat-lbl{opacity:1;}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.topbar{height:56px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 24px;gap:14px;flex-shrink:0;}
.tb-title{font-size:15px;font-weight:600;}.tb-title span{color:var(--accent);}
.tb-bc{display:flex;align-items:center;gap:6px;font-size:11.5px;color:var(--muted);font-family:var(--mono);}
.tb-bc .sep{color:var(--dim);}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
.tb-badge{font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;font-family:var(--mono);}
.tb-badge.live{background:var(--gb);border:1px solid var(--gbr);color:var(--green);}
.tb-badge.act{background:rgba(59,130,246,.12);border:1px solid rgba(59,130,246,.25);color:var(--accent);}
.tb-a{font-size:12px;font-weight:500;color:var(--sub);text-decoration:none;padding:5px 10px;border-radius:6px;transition:.15s;}
.tb-a:hover{color:var(--accent);background:var(--ag);}

.content{flex:1;overflow-y:auto;padding:28px 32px 60px;}
.content::-webkit-scrollbar{width:5px;}
.content::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}
.panel{display:none;}.panel.active,#panel-upload{display:block;}

/* SECTION HDR */
.shdr{margin-bottom:22px;}
.shdr h1{font-size:22px;font-weight:700;letter-spacing:-.4px;margin-bottom:4px;}
.shdr h1 em{font-style:normal;color:var(--accent);}
.shdr p{font-size:13px;color:var(--sub);line-height:1.6;}

/* CARD */
.card{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:14px;}
.card-hdr{padding:11px 18px;background:var(--surface2);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.cnum{width:22px;height:22px;border-radius:6px;background:var(--accent);color:#fff;font-size:11px;font-weight:700;display:grid;place-items:center;flex-shrink:0;font-family:var(--mono);}
.ctitle{font-size:10.5px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--sub);}
.cbadge{margin-left:auto;font-size:9px;font-weight:700;padding:2px 8px;border-radius:4px;font-family:var(--mono);}
.cbadge.def{background:rgba(59,130,246,.15);border:1px solid rgba(59,130,246,.3);color:var(--accent);}
.cbadge.ok{background:var(--gb);border:1px solid var(--gbr);color:var(--green);}
.card-body{padding:20px;}

/* FORM */
.fg{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.fg3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
.field{display:flex;flex-direction:column;gap:5px;}
.field label{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);font-family:var(--mono);}
.field input,.field select,.field textarea{background:var(--surface3);border:1px solid var(--border2);border-radius:7px;padding:9px 12px;color:var(--text);font-size:13px;font-family:var(--sans);outline:none;transition:.15s;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--accent);background:var(--surface2);box-shadow:0 0 0 3px var(--ag);}
.field input::placeholder,.field textarea::placeholder{color:var(--muted);}
.field select option{background:var(--surface2);}
.field-cb{display:flex;align-items:center;gap:9px;margin-top:8px;}
.field-cb input[type=checkbox]{width:15px;height:15px;accent-color:var(--accent);cursor:pointer;}
.field-cb label{font-size:13px;color:var(--sub);cursor:pointer;}
.div{height:1px;background:var(--border);margin:16px 0;}

/* ENV GRID */
.eg{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.ec{border:1.5px solid var(--border2);border-radius:9px;padding:12px 14px;cursor:pointer;background:var(--surface3);transition:.15s;user-select:none;}
.ec:hover{background:var(--surface2);}
.ec.active{border-color:var(--accent);background:rgba(59,130,246,.08);}
.ec.active .en{color:var(--accent);}
.ec.prd.active{border-color:var(--red);background:var(--rb);}
.ec.prd.active .en{color:var(--red);}
.en{font-size:13px;font-weight:600;margin-bottom:3px;}
.eh{font-size:10.5px;font-family:var(--mono);color:var(--muted);}
.etag{display:inline-block;margin-top:5px;font-size:9px;font-weight:700;padding:1px 7px;border-radius:3px;text-transform:uppercase;}
.etag.dev{background:rgba(59,130,246,.15);color:var(--accent);}
.etag.prd{background:var(--rb);color:var(--red);}

/* DROP ZONE */
.drop{border:2px dashed var(--border2);border-radius:10px;padding:38px 20px;text-align:center;cursor:pointer;background:var(--surface3);transition:.2s;position:relative;}
.drop:hover,.drop.over{border-color:var(--accent);background:rgba(59,130,246,.05);}
.drop input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.drop-icon{font-size:42px;margin-bottom:10px;line-height:1;}
.drop-main{font-size:14px;font-weight:600;color:var(--sub);margin-bottom:4px;}
.drop-sub{font-size:11.5px;color:var(--muted);font-family:var(--mono);}
.fp{display:flex;align-items:center;gap:10px;background:var(--gb);border:1px solid var(--gbr);border-radius:8px;padding:10px 14px;margin-top:12px;display:none;}
.fp .fpi{font-size:18px;}
.fp .fpn{font-size:13px;font-weight:600;color:var(--green);font-family:var(--mono);}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;padding:10px 20px;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:.15s;font-family:var(--sans);}
.btn-p{background:linear-gradient(135deg,var(--accent),var(--accent-dark));color:#fff;box-shadow:0 4px 14px rgba(59,130,246,.35);}
.btn-p:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(59,130,246,.45);}
.btn-p:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none;}
.btn-full{width:100%;}
.btn-s{background:var(--surface3);border:1px solid var(--border2);color:var(--sub);}
.btn-s:hover{border-color:var(--accent);color:var(--accent);}
.btn-ok{background:var(--gb);border:1px solid var(--gbr);color:var(--green);}
.btn-sm{padding:6px 14px;font-size:12px;}

/* STEPS */
.steps{display:flex;flex-direction:column;gap:8px;}
.step{display:flex;align-items:flex-start;gap:12px;padding:12px 14px;border:1px solid var(--border2);border-radius:9px;background:var(--surface3);transition:.3s;}
.step.run{border-color:rgba(59,130,246,.4);background:rgba(59,130,246,.06);}
.step.done{border-color:var(--gbr);background:var(--gb);}
.step.err{border-color:var(--rbr);background:var(--rb);}
.si{width:24px;height:24px;border-radius:6px;background:var(--border2);display:grid;place-items:center;font-size:12px;flex-shrink:0;font-family:var(--mono);color:var(--muted);}
.step.run .si{background:var(--accent);color:#fff;}
.step.done .si{background:var(--green);color:#fff;}
.step.err  .si{background:var(--red);color:#fff;}
.sl{font-size:13px;font-weight:500;color:var(--sub);}
.step.run .sl{color:var(--accent);}
.step.done .sl{color:var(--green);}
.step.err  .sl{color:var(--red);}
.sd{font-size:10.5px;font-family:var(--mono);color:var(--muted);margin-top:3px;word-break:break-all;}

/* RESULT */
.rbox{text-align:center;padding:30px 24px;}
.ricon{font-size:54px;margin-bottom:14px;line-height:1;}
.rtitle{font-size:22px;font-weight:700;letter-spacing:-.4px;color:var(--green);margin-bottom:5px;}
.rsub{font-size:13px;color:var(--sub);margin-bottom:20px;}
.ep-disp{background:var(--surface3);border:1px solid var(--border2);border-radius:9px;padding:14px 18px;font-family:var(--mono);font-size:12px;text-align:left;line-height:2;margin-bottom:18px;}
.ep-lbl{font-size:9.5px;color:var(--muted);display:block;margin-top:8px;text-transform:uppercase;letter-spacing:.8px;}
.chips{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;}
.chip{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:20px;font-size:12px;font-weight:600;text-decoration:none;transition:.15s;}
.cg{background:var(--gb);border:1px solid var(--gbr);color:var(--green);}
.cb{background:rgba(59,130,246,.12);border:1px solid rgba(59,130,246,.25);color:var(--accent);}
.cp{background:var(--pb);border:1px solid rgba(168,85,247,.25);color:var(--purple);}

/* SWAGGER PANEL */
#panel-swagger{height:calc(100vh - 56px);overflow-y:auto;}
#panel-swagger::-webkit-scrollbar{width:5px;}
#panel-swagger::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}
.swagger-ui{font-family:var(--sans) !important;background:var(--bg) !important;}
.swagger-ui .topbar{display:none !important;}
.swagger-ui .info{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px 24px;margin:20px 20px 0;}
.swagger-ui .info .title{color:var(--text) !important;font-family:var(--sans) !important;}
.swagger-ui .info p{color:var(--sub) !important;}
.swagger-ui .scheme-container{background:var(--surface2) !important;border:1px solid var(--border) !important;box-shadow:none !important;padding:10px 20px !important;margin:0 20px !important;}
.swagger-ui .opblock-tag{color:var(--text) !important;border-bottom:1px solid var(--border) !important;font-family:var(--sans) !important;}
.swagger-ui .opblock.opblock-post{background:rgba(34,197,94,.05) !important;border:1px solid rgba(34,197,94,.18) !important;border-radius:8px !important;margin-bottom:6px !important;}
.swagger-ui .opblock.opblock-post .opblock-summary-method{background:var(--green) !important;}
.swagger-ui .opblock-body,.swagger-ui .opblock-section{background:var(--surface3) !important;}
.swagger-ui .btn.execute{background:var(--accent) !important;border-color:var(--accent) !important;}
.swagger-ui input[type=text],.swagger-ui textarea{background:var(--surface3) !important;color:var(--text) !important;border:1px solid var(--border2) !important;}
.swagger-ui .models{margin:20px !important;}
.swagger-ui .wrapper{padding:0 !important;}
.swagger-ui section.models{background:var(--surface) !important;border:1px solid var(--border) !important;border-radius:8px !important;}

/* IIS CONFIG */
.status-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px;}
.sc{background:var(--surface2);border:1px solid var(--border);border-radius:9px;padding:14px;}
.sc .scl{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;font-family:var(--mono);}
.sc .scv{font-size:13px;font-weight:600;color:var(--text);font-family:var(--mono);}
.sdot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:5px;}
.sdot.g{background:var(--green);}
.sdot.r{background:var(--red);}
.sdot.a{background:var(--amber);}

/* INNER TABS */
.itabs{display:flex;gap:2px;background:var(--surface2);border-radius:8px;padding:3px;margin-bottom:18px;}
.itab{flex:1;padding:7px 12px;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;transition:.15s;text-align:center;color:var(--muted);border:none;background:none;font-family:var(--sans);}
.itab.active{background:var(--surface);color:var(--text);box-shadow:0 1px 3px rgba(0,0,0,.3);}

/* CONFIG TABLE */
.ctbl{width:100%;border-collapse:collapse;}
.ctbl th{padding:8px 14px;font-size:9.5px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);text-align:left;border-bottom:1px solid var(--border);font-family:var(--mono);}
.ctbl td{padding:8px 14px;font-size:12.5px;border-bottom:1px solid var(--border);color:var(--sub);}
.ctbl tr:last-child td{border-bottom:none;}
.ctbl tr:hover td{background:rgba(255,255,255,.02);}
.ck{font-family:var(--mono);color:var(--accent);font-weight:500;}
.cv{font-family:var(--mono);color:var(--text);}
.cs{font-size:10px;font-weight:700;padding:2px 8px;border-radius:4px;font-family:var(--mono);}
.cs.ok{background:var(--gb);color:var(--green);}
.cs.pend{background:var(--amb);color:var(--amber);}

/* ALERT */
.alert{padding:10px 14px;border-radius:7px;font-size:12.5px;font-family:var(--mono);margin-top:12px;display:none;}
.alert.ok{background:var(--gb);border:1px solid var(--gbr);color:var(--green);}
.alert.err{background:var(--rb);border:1px solid var(--rbr);color:var(--red);}
.alert.info{background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.25);color:var(--accent);}

/* SPIN */
.spin{display:inline-block;width:13px;height:13px;border:2px solid currentColor;border-top-color:transparent;border-radius:50%;animation:rot .65s linear infinite;}
@keyframes rot{to{transform:rotate(360deg)}}

/* FLOW BAR */
.fbar{display:flex;align-items:center;gap:6px;margin-bottom:22px;flex-wrap:wrap;}
.fn{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:6px 12px;font-size:11px;font-weight:600;color:var(--sub);}
.fn.hl{border-color:rgba(59,130,246,.4);background:rgba(59,130,246,.08);color:var(--accent);}
.farr{color:var(--dim);font-size:14px;}

@@media(max-width:900px){.status-grid{grid-template-columns:1fr 1fr;}.fg{grid-template-columns:1fr;}.eg{grid-template-columns:1fr 1fr;}}
</style>
</head>
<body>
<div class="shell">

  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="s-logo">
      <div class="s-logo-icon">V2</div>
      <span class="s-logo-text">RFC Portal</span>
    </div>
    <div class="nav-items">
      <div class="ni active" id="nav-upload"   onclick="showPanel('upload')">  <span class="ni-icon">⚡</span><span class="ni-label">Deploy RFC</span></div>
      <div class="ni"        id="nav-swagger"  onclick="showPanel('swagger')"> <span class="ni-icon">📖</span><span class="ni-label">Swagger UI</span></div>
      <div class="ni"        id="nav-iis"      onclick="showPanel('iis')">     <span class="ni-icon">🖥</span><span class="ni-label">IIS Config</span></div>
      <div class="ni"        id="nav-explorer" onclick="openExplorer()">       <span class="ni-icon">🔍</span><span class="ni-label">API Explorer</span></div>
    </div>
    <div class="s-foot">
      <div class="s-stat"><span class="sdot"></span><span class="s-stat-lbl">IIS LIVE</span></div>
    </div>
  </nav>

  <!-- MAIN -->
  <div class="main">
    <div class="topbar">
      <div class="tb-title">V2 Retail · <span>RFC Pipeline</span></div>
      <div class="tb-bc"><span>akash0631/rfc-api</span><span class="sep">/</span><span id="tbc">Deploy RFC</span></div>
      <div class="tb-right">
        <span class="tb-badge live">● IIS LIVE</span>
        <a href="https://github.com/akash0631/rfc-api/actions" target="_blank" class="tb-badge act">⚙ Actions</a>
        <a href="/RfcDeploy/Explorer" class="tb-a">Explorer →</a>
      </div>
    </div>

    <!-- ═══ PANEL: DEPLOY RFC ═══ -->
    <div class="content" id="panel-upload">
      <div class="shdr">
        <h1>Deploy RFC <em>Document</em> to Live API</h1>
        <p>Upload a SAP RFC spec (.docx) — Claude AI parses it, generates the C# controller, pushes to GitHub, and IIS deploys automatically.</p>
      </div>
      <div class="fbar">
        <div class="fn">📄 Upload .docx</div><div class="farr">→</div>
        <div class="fn hl">🤖 Claude AI</div><div class="farr">→</div>
        <div class="fn">⚙ C# Generated</div><div class="farr">→</div>
        <div class="fn">📦 GitHub Push</div><div class="farr">→</div>
        <div class="fn">🌐 IIS Live</div>
      </div>

      <div id="uploadForm">
        <div class="card">
          <div class="card-hdr"><div class="cnum">1</div><span class="ctitle">RFC Document</span></div>
          <div class="card-body">
            <div class="drop" id="drop" ondragover="event.preventDefault();this.classList.add('over')" ondragleave="this.classList.remove('over')" ondrop="handleDrop(event)">
              <div class="drop-icon">📄</div>
              <div class="drop-main">Drop your RFC document here</div>
              <div class="drop-sub">.docx &nbsp;·&nbsp; .txt &nbsp;·&nbsp; .md</div>
              <input type="file" id="fileInput" accept=".docx,.txt,.md" onchange="handleFile(this.files[0])">
            </div>
            <div class="fp" id="fp"><span class="fpi">📎</span><span class="fpn" id="fn2"></span></div>
          </div>
        </div>

        <div class="card">
          <div class="card-hdr"><div class="cnum">2</div><span class="ctitle">SAP Environment</span></div>
          <div class="card-body">
            <div class="eg">
              <div class="ec active" id="env-dev"        onclick="selEnv('dev')">        <div class="en">Dev</div>        <div class="eh">192.168.144.174 · Client 210</div><span class="etag dev">DEFAULT</span></div>
              <div class="ec"        id="env-quality"    onclick="selEnv('quality')">    <div class="en">Quality</div>    <div class="eh">192.168.144.179 · Client 600</div><span class="etag dev">QA</span></div>
              <div class="ec prd"    id="env-production" onclick="selEnv('production')"> <div class="en" style="color:var(--red)">Production</div><div class="eh">192.168.144.170 · Client 600</div><span class="etag prd">LIVE</span></div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-hdr"><div class="cnum">3</div><span class="ctitle">Controller Settings</span><span class="cbadge def">Auto-detected from doc</span></div>
          <div class="card-body">
            <div class="fg">
              <div class="field">
                <label>Folder / Module</label>
                <select id="ctrlFolder">
                  <option value="">Auto-detect from RFC name</option>
                  <option value="Finance">Finance</option>
                  <option value="Inbound">Inbound</option>
