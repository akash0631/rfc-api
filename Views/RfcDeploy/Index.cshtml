@{
    ViewBag.Title = "RFC Deploy Wizard";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>RFC Deploy Wizard — V2 Retail</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/5.17.14/swagger-ui.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f5f6fa;--white:#fff;--border:#e2e6ef;--border2:#cdd3e0;
  --text:#1a2035;--sub:#4a5568;--muted:#8896ab;
  --accent:#2563eb;--al:#eff6ff;--ab:#bfdbfe;
  --green:#16a34a;--gl:#f0fdf4;--gb:#86efac;
  --red:#dc2626;--rl:#fef2f2;--rb:#fca5a5;
  --amber:#d97706;
  --sans:'DM Sans',system-ui,sans-serif;
  --mono:'DM Mono',Consolas,monospace;
}
body{background:var(--bg);font-family:var(--sans);color:var(--text);min-height:100vh;}

/* HEADER */
header{background:var(--white);border-bottom:1px solid var(--border);padding:0 32px;height:54px;display:flex;align-items:center;gap:12px;}
.logo{width:28px;height:28px;background:var(--accent);border-radius:7px;display:grid;place-items:center;font-weight:700;color:#fff;font-size:12px;font-family:var(--mono);}
.logo-name{font-size:14px;font-weight:700;color:var(--text);}
.logo-name span{color:var(--accent);}
.header-right{margin-left:auto;font-size:12px;color:var(--muted);}

/* WIZARD WRAPPER */
.wizard{max-width:780px;margin:36px auto;padding:0 16px 80px;}

/* STEPPER */
.stepper{display:flex;align-items:flex-start;gap:0;margin-bottom:36px;position:relative;}
.stepper::before{content:'';position:absolute;top:18px;left:18px;right:18px;height:2px;background:var(--border);z-index:0;}
.step-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;position:relative;z-index:1;cursor:pointer;}
.step-circle{width:36px;height:36px;border-radius:50%;border:2px solid var(--border);background:var(--white);display:grid;place-items:center;font-size:13px;font-weight:700;color:var(--muted);transition:.25s;}
.step-circle.active{border-color:var(--accent);background:var(--accent);color:#fff;}
.step-circle.done{border-color:var(--green);background:var(--green);color:#fff;}
.step-label{font-size:11px;font-weight:600;color:var(--muted);text-align:center;line-height:1.3;white-space:nowrap;}
.step-label.active{color:var(--accent);}
.step-label.done{color:var(--green);}

/* PANEL */
.panel{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:28px;display:none;}
.panel.active{display:block;}
.panel-title{font-size:18px;font-weight:700;margin-bottom:4px;}
.panel-sub{font-size:13px;color:var(--sub);margin-bottom:24px;line-height:1.6;}

/* FORM */
.field{margin-bottom:16px;}
.field label{display:block;font-size:11.5px;font-weight:700;color:var(--sub);text-transform:uppercase;letter-spacing:.7px;margin-bottom:5px;}
.field input,.field select,.field textarea{
  width:100%;background:var(--bg);border:1.5px solid var(--border);border-radius:8px;
  padding:10px 13px;font-size:13.5px;font-family:var(--sans);color:var(--text);outline:none;transition:.15s;
}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--accent);background:var(--white);box-shadow:0 0 0 3px rgba(37,99,235,.08);}
.field input::placeholder{color:var(--muted);}
.field textarea{resize:vertical;min-height:90px;}
.field .hint{font-size:11px;color:var(--muted);margin-top:4px;font-family:var(--mono);}
.field select option{background:var(--white);}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
.checkbox-row{display:flex;align-items:center;gap:9px;margin-bottom:10px;}
.checkbox-row input{width:16px;height:16px;accent-color:var(--accent);cursor:pointer;}
.checkbox-row label{font-size:13px;color:var(--sub);cursor:pointer;}

/* DROP ZONE */
.dropzone{border:2px dashed var(--border2);border-radius:10px;padding:44px 20px;text-align:center;cursor:pointer;background:var(--bg);transition:.2s;position:relative;}
.dropzone:hover,.dropzone.over{border-color:var(--accent);background:var(--al);}
.dropzone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.dz-icon{font-size:40px;margin-bottom:10px;line-height:1;}
.dz-title{font-size:15px;font-weight:600;margin-bottom:4px;color:var(--sub);}
.dz-hint{font-size:12px;color:var(--muted);font-family:var(--mono);}
.file-pill{display:none;align-items:center;gap:10px;background:var(--gl);border:1px solid var(--gb);border-radius:8px;padding:10px 14px;margin-top:12px;}
.fp-icon{font-size:18px;}
.fp-name{font-size:13px;font-weight:600;color:var(--green);font-family:var(--mono);}

/* CODE PREVIEW */
.code-box{background:#f8f9fc;border:1.5px solid var(--border);border-radius:9px;padding:16px;font-family:var(--mono);font-size:12px;color:var(--sub);max-height:320px;overflow-y:auto;white-space:pre;line-height:1.65;}
.code-box::-webkit-scrollbar{width:4px;}
.code-box::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}

/* BUTTONS */
.btn-row{display:flex;gap:10px;margin-top:24px;}
.btn{padding:10px 22px;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;transition:.15s;border:none;font-family:var(--sans);}
.btn-primary{background:var(--accent);color:#fff;box-shadow:0 3px 10px rgba(37,99,235,.25);}
.btn-primary:hover{background:#1d4ed8;}
.btn-primary:disabled{opacity:.45;cursor:not-allowed;}
.btn-secondary{background:var(--white);border:1.5px solid var(--border);color:var(--sub);}
.btn-secondary:hover{border-color:var(--accent);color:var(--accent);}
.btn-success{background:var(--green);color:#fff;}
.btn-success:hover{background:#15803d;}

/* ALERTS */
.alert{padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:14px;display:none;}
.alert.ok{background:var(--gl);border:1px solid var(--gb);color:var(--green);}
.alert.err{background:var(--rl);border:1px solid var(--rb);color:var(--red);}
.alert.info{background:var(--al);border:1px solid var(--ab);color:var(--accent);}

/* TAGS */
.tag{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:5px;font-size:11px;font-weight:700;font-family:var(--mono);}
.tag-post{background:#f0fdf4;border:1px solid var(--gb);color:var(--green);}
.tag-env{background:var(--al);border:1px solid var(--ab);color:var(--accent);}

/* SWAGGER-LIKE ENDPOINT CARD */
.ep-card{border:1.5px solid var(--gb);border-radius:10px;background:var(--gl);padding:16px 18px;margin-bottom:14px;}
.ep-head{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.ep-path{font-size:14px;font-weight:700;font-family:var(--mono);color:var(--text);}
.ep-desc{font-size:13px;color:var(--sub);margin-bottom:12px;}
.param-table{width:100%;border-collapse:collapse;}
.param-table th{padding:7px 12px;font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--muted);text-align:left;border-bottom:1px solid var(--border);}
.param-table td{padding:7px 12px;font-size:12.5px;border-bottom:1px solid var(--border);color:var(--sub);}
.param-table tr:last-child td{border-bottom:none;}
.pname{color:var(--accent);font-family:var(--mono);}
.ptype{font-family:var(--mono);font-size:11px;background:var(--bg);border:1px solid var(--border);padding:1px 6px;border-radius:4px;}
.preq{font-size:10px;font-weight:700;padding:1px 7px;border-radius:4px;background:var(--gl);border:1px solid var(--gb);color:var(--green);}
.popt{font-size:10px;font-weight:700;padding:1px 7px;border-radius:4px;background:var(--bg);border:1px solid var(--border);color:var(--muted);}

/* RESPONSE EXAMPLE */
.resp-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--muted);margin-bottom:5px;}
.resp-box{background:#f8f9fc;border:1px solid var(--border);border-radius:7px;padding:10px 12px;font-family:var(--mono);font-size:12px;color:var(--sub);}

/* PIPELINE STATUS */
.pipeline{display:flex;flex-direction:column;gap:8px;}
.pipe-step{display:flex;align-items:center;gap:12px;padding:12px 14px;border:1.5px solid var(--border);border-radius:9px;background:var(--bg);}
.pipe-step.run{border-color:var(--ab);background:var(--al);}
.pipe-step.done{border-color:var(--gb);background:var(--gl);}
.pipe-step.err{border-color:var(--rb);background:var(--rl);}
.pipe-icon{width:26px;height:26px;border-radius:6px;background:var(--border);display:grid;place-items:center;font-size:13px;font-weight:700;flex-shrink:0;font-family:var(--mono);color:var(--muted);}
.pipe-step.run .pipe-icon{background:var(--accent);color:#fff;}
.pipe-step.done .pipe-icon{background:var(--green);color:#fff;}
.pipe-step.err  .pipe-icon{background:var(--red);color:#fff;}
.pipe-label{font-size:13.5px;font-weight:500;color:var(--sub);}
.pipe-step.run .pipe-label{color:var(--accent);}
.pipe-step.done .pipe-label{color:var(--green);}
.pipe-step.err  .pipe-label{color:var(--red);}
.pipe-detail{font-size:11px;font-family:var(--mono);color:var(--muted);margin-top:2px;}

/* RESULT */
.result-center{text-align:center;padding:24px 0;}
.result-icon{font-size:52px;margin-bottom:12px;}
.result-title{font-size:20px;font-weight:700;color:var(--green);margin-bottom:6px;}
.result-sub{font-size:13px;color:var(--sub);margin-bottom:20px;}
.result-links{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;}
.rlink{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:12.5px;font-weight:600;text-decoration:none;transition:.15s;}
.rlink-g{background:var(--gl);border:1px solid var(--gb);color:var(--green);}
.rlink-b{background:var(--al);border:1px solid var(--ab);color:var(--accent);}

/* SPIN */
.spin{display:inline-block;width:13px;height:13px;border:2px solid currentColor;border-top-color:transparent;border-radius:50%;animation:rot .65s linear infinite;}
@@keyframes rot{to{transform:rotate(360deg)}}

/* SECTION DIVIDER */
.sdiv{height:1px;background:var(--border);margin:20px 0;}

/* swagger embed override */
.swagger-panel .swagger-ui .topbar{display:none !important;}
.swagger-panel .swagger-ui{font-family:var(--sans) !important;}
.swagger-panel .swagger-ui .opblock.opblock-post{background:var(--gl) !important;border-color:var(--gb) !important;}
.swagger-panel .swagger-ui .opblock.opblock-post .opblock-summary-method{background:var(--green) !important;}
.swagger-panel .swagger-ui .info .title{font-size:16px !important;margin-bottom:4px;}
</style>
</head>
<body>

<header>
  <div class="logo">V2</div>
  <span class="logo-name">Retail <span>RFC</span> Deploy Wizard</span>
  <div class="header-right">akash0631/rfc-api &nbsp;·&nbsp; IIS V2DC-ADDVERB</div>
</header>

<div class="wizard">

  <!-- STEPPER -->
  <div class="stepper">
    <div class="step-item" onclick="goStep(1)">
      <div class="step-circle active" id="sc1">1</div>
      <div class="step-label active"  id="sl1">Upload<br>Document</div>
    </div>
    <div class="step-item" onclick="goStep(2)">
      <div class="step-circle" id="sc2">2</div>
      <div class="step-label" id="sl2">Controller<br>Code</div>
    </div>
    <div class="step-item" onclick="goStep(3)">
      <div class="step-circle" id="sc3">3</div>
      <div class="step-label" id="sl3">API<br>Preview</div>
    </div>
    <div class="step-item" onclick="goStep(4)">
      <div class="step-circle" id="sc4">4</div>
      <div class="step-label" id="sl4">GitHub<br>Push</div>
    </div>
    <div class="step-item" onclick="goStep(5)">
      <div class="step-circle" id="sc5">5</div>
      <div class="step-label" id="sl5">IIS<br>Deploy</div>
    </div>
  </div>

  <!-- ═══ STEP 1: UPLOAD ═══ -->
  <div class="panel active" id="step1">
    <div class="panel-title">Upload RFC Document</div>
    <div class="panel-sub">Upload your SAP RFC specification file. The wizard will automatically parse the RFC name, parameters, and response types.</div>

    <div class="dropzone" id="dz"
         ondragover="event.preventDefault();this.classList.add('over')"
         ondragleave="this.classList.remove('over')"
         ondrop="handleDrop(event)">
      <div class="dz-icon">📄</div>
      <div class="dz-title">Drop RFC document here</div>
      <div class="dz-hint">.docx &nbsp;·&nbsp; .txt &nbsp;·&nbsp; .md — or click to browse</div>
      <input type="file" id="fileInput" accept=".docx,.txt,.md" onchange="handleFile(this.files[0])">
    </div>
    <div class="file-pill" id="filePill">
      <span class="fp-icon">📎</span>
      <span class="fp-name" id="fileName"></span>
    </div>

    <div class="sdiv"></div>

    <div class="row2">
      <div class="field">
        <label>SAP Environment</label>
        <select id="sapEnv" onchange="updateEnvInfo()">
          <option value="dev" selected>Dev — 192.168.144.174 · Client 210</option>
          <option value="quality">Quality — 192.168.144.179 · Client 600</option>
          <option value="production">Production — 192.168.144.170 · Client 600</option>
        </select>
        <div class="hint" id="envHint">SAP Dev RFC connection · rfcConfigparameters()</div>
      </div>
      <div class="field">
        <label>Controller Folder</label>
        <select id="ctrlFolder">
          <option value="Finance" selected>Finance</option>
          <option value="Inbound">Inbound</option>
          <option value="HU_Creation">HU Creation</option>
          <option value="GateEntry_LOT_Putway">Gate Entry / LOT Putway</option>
          <option value="PaperlessPicklist">Paperless Picklist</option>
          <option value="Vehicle_Loading">Vehicle Loading</option>
          <option value="DcRouting">DC Routing</option>
          <option value="Vendor_SRM_Routing">Vendor SRM / Routing</option>
          <option value="HRMS">HRMS</option>
          <option value="Sampling">Sampling</option>
        </select>
      </div>
    </div>

    <div class="alert info" id="parseAlert">🤖 Parsing RFC document with Claude AI...</div>

    <div class="btn-row">
      <button class="btn btn-primary" id="btn1" onclick="step1Next()" disabled>Parse &amp; Continue →</button>
    </div>
  </div>

  <!-- ═══ STEP 2: CONTROLLER CODE ═══ -->
  <div class="panel" id="step2">
    <div class="panel-title">Review &amp; Edit Controller</div>
    <div class="panel-sub">Generated C# controller code based on your RFC document. Review and edit before pushing to GitHub.</div>

    <div class="row2">
      <div class="field">
        <label>RFC Function Name</label>
        <input type="text" id="rfcName" placeholder="e.g. ZPO_DD_UPD_RFC">
      </div>
      <div class="field">
        <label>Controller File Name</label>
        <input type="text" id="ctrlFileName" placeholder="e.g. ZPO_DD_UPD_RFCController.cs">
      </div>
    </div>

    <div class="field">
      <label>Description</label>
      <input type="text" id="rfcDesc" placeholder="What does this RFC do?">
    </div>

    <div class="field">
      <label>Generated C# Controller Code</label>
      <textarea id="ctrlCode" style="min-height:300px;font-family:var(--mono);font-size:12px;line-height:1.6;background:#f8f9fc;"></textarea>
    </div>

    <div class="alert ok" id="codeOk" style="display:none">✓ Controller code ready</div>
    <div class="alert err" id="codeErr" style="display:none"></div>

    <div class="btn-row">
      <button class="btn btn-secondary" onclick="goStep(1)">← Back</button>
      <button class="btn btn-primary" onclick="goStep(3)">Preview API →</button>
    </div>
  </div>

  <!-- ═══ STEP 3: API PREVIEW ═══ -->
  <div class="panel" id="step3">
    <div class="panel-title">API Preview</div>
    <div class="panel-sub">How your RFC will look as a REST API endpoint once deployed on IIS.</div>

    <div class="ep-card">
      <div class="ep-head">
        <span class="tag tag-post">POST</span>
        <span class="ep-path" id="apiPath">/api/RFC_NAME</span>
        <span class="tag tag-env" id="apiEnvTag">DEV · 192.168.144.174</span>
      </div>
      <div class="ep-desc" id="apiDesc">RFC description</div>

      <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--muted);margin-bottom:8px;">Request Body (application/json)</div>
      <div class="code-box" id="apiReqExample" style="min-height:60px;margin-bottom:14px;"></div>

      <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--muted);margin-bottom:6px;">Parameters</div>
      <table class="param-table" id="apiParamTable">
        <thead><tr><th>Name</th><th>SAP Type</th><th>Required</th><th>Description</th></tr></thead>
        <tbody id="apiParamBody"></tbody>
      </table>

      <div class="sdiv"></div>
      <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:var(--muted);margin-bottom:6px;">Response</div>
      <div class="row2">
        <div>
          <div class="resp-label">200 Success</div>
          <div class="resp-box">{"Status": true, "MsgType": "S", "Message": "Updated successfully"}</div>
        </div>
        <div>
          <div class="resp-label">400 SAP Error</div>
          <div class="resp-box">{"Status": false, "MsgType": "E", "Message": "SAP error text"}</div>
        </div>
      </div>
    </div>

    <div style="background:var(--al);border:1px solid var(--ab);border-radius:8px;padding:12px 16px;font-size:12.5px;color:var(--accent);margin-top:4px;">
      <strong>Full Swagger UI</strong> available at <code style="font-family:var(--mono)">/RfcDeploy/SwaggerUI</code> after deploy &nbsp;·&nbsp; OpenAPI JSON at <code style="font-family:var(--mono)">/RfcDeploy/OpenApiJson</code>
    </div>

    <div class="btn-row">
      <button class="btn btn-secondary" onclick="goStep(2)">← Back</button>
      <button class="btn btn-primary" onclick="goStep(4)">Configure GitHub →</button>
    </div>
  </div>

  <!-- ═══ STEP 4: GITHUB PUSH ═══ -->
  <div class="panel" id="step4">
    <div class="panel-title">Push to GitHub</div>
    <div class="panel-sub">Review settings and push the generated controller to GitHub. This will automatically trigger the IIS build pipeline.</div>

    <div class="row2">
      <div class="field">
        <label>GitHub Repository</label>
        <input type="text" id="ghRepo" value="akash0631/rfc-api">
        <div class="hint">owner/repo</div>
      </div>
      <div class="field">
        <label>Branch</label>
        <input type="text" id="ghBranch" value="master">
      </div>
    </div>

    <div class="field">
      <label>GitHub Token</label>
      <input type="password" id="ghToken" value="YOUR_GITHUB_TOKEN_HERE" autocomplete="off">
      <div class="hint">Stored securely — used only for this push</div>
    </div>

    <div class="field">
      <label>Commit Message</label>
      <input type="text" id="commitMsg" placeholder="Auto-filled from RFC name">
    </div>

    <div class="field">
      <label>Controller File Path in Repo</label>
      <input type="text" id="ghFilePath" placeholder="e.g. Controllers/Finance/ZPO_DD_UPD_RFCController.cs">
      <div class="hint">Auto-filled based on folder selection</div>
    </div>

    <div class="sdiv"></div>
    <div style="font-size:12px;color:var(--sub);margin-bottom:14px;">
      ⚙ After push, GitHub Actions (<code style="font-family:var(--mono)">deploy-iis.yml</code>) triggers automatically on VM-CRM and builds + deploys to IIS in ~90s.
    </div>

    <!-- Push status -->
    <div id="pushArea" style="display:none">
      <div class="pipeline" id="pushPipeline">
        <div class="pipe-step" id="pp-check">   <div class="pipe-icon">1</div><div><div class="pipe-label">Check file exists in repo</div><div class="pipe-detail" id="pp-check-d"></div></div></div>
        <div class="pipe-step" id="pp-push">    <div class="pipe-icon">2</div><div><div class="pipe-label">Push controller to GitHub</div><div class="pipe-detail" id="pp-push-d"></div></div></div>
        <div class="pipe-step" id="pp-actions"> <div class="pipe-icon">3</div><div><div class="pipe-label">GitHub Actions triggered</div><div class="pipe-detail" id="pp-actions-d"></div></div></div>
      </div>
    </div>

    <div class="alert ok"  id="pushOk"  style="display:none"></div>
    <div class="alert err" id="pushErr" style="display:none"></div>

    <div class="btn-row">
      <button class="btn btn-secondary" onclick="goStep(3)">← Back</button>
      <button class="btn btn-primary" id="btnPush" onclick="doPush()">📦 Push to GitHub</button>
      <button class="btn btn-primary" id="btnNext4" onclick="goStep(5)" style="display:none">Configure IIS →</button>
    </div>
  </div>

  <!-- ═══ STEP 5: IIS DEPLOY ═══ -->
  <div class="panel" id="step5">
    <div class="panel-title">IIS Deploy Configuration</div>
    <div class="panel-sub">Configure your publish settings. All fields are pre-filled with V2 Retail defaults — change only what's needed.</div>

    <div class="row2">
      <div class="field">
        <label>IIS Server</label>
        <input type="text" id="iisServer" value="192.168.151.24">
        <div class="hint">V2DC-ADDVERB</div>
      </div>
      <div class="field">
        <label>IIS Site Name</label>
        <input type="text" id="iisSite" value="Store Tracker">
      </div>
    </div>

    <div class="row2">
      <div class="field">
        <label>Web App Physical Path</label>
        <input type="text" id="iisPath" value="C:\inetpub\wwwroot\Store Tracker">
      </div>
      <div class="field">
        <label>App Pool Name</label>
        <input type="text" id="iisPool" value="StoreTracker">
      </div>
    </div>

    <div class="row3">
      <div class="field">
        <label>Build Config</label>
        <select id="buildCfg">
          <option value="Release" selected>Release</option>
          <option value="Debug">Debug</option>
        </select>
      </div>
      <div class="field">
        <label>Framework</label>
        <select id="buildFx">
          <option value="v4.7.2" selected>.NET 4.7.2</option>
          <option value="v4.8">.NET 4.8</option>
        </select>
      </div>
      <div class="field">
        <label>GitHub Actions Runner</label>
        <input type="text" id="iisRunner" value="192.168.151.46 (VM-CRM)">
      </div>
    </div>

    <div class="field">
      <label>MSBuild Path</label>
      <input type="text" id="msbuildPath" value="C:\Windows\Microsoft.NET\Framework64\v4.0.30319\MSBuild.exe">
    </div>

    <div class="sdiv"></div>
    <div style="font-size:12px;font-weight:700;color:var(--sub);margin-bottom:10px;">Publish Options</div>
    <div class="checkbox-row"><input type="checkbox" id="optRecycle" checked><label for="optRecycle">Recycle App Pool after deploy</label></div>
    <div class="checkbox-row"><input type="checkbox" id="optSync" checked><label for="optSync">Trigger SAP sync after deploy</label></div>
    <div class="checkbox-row"><input type="checkbox" id="optSwagger" checked><label for="optSwagger">Update Swagger/Explorer documentation</label></div>
    <div class="checkbox-row"><input type="checkbox" id="optDab" checked><label for="optDab">Register in Azure DAB (data lake)</label></div>

    <div class="sdiv"></div>

    <!-- Deploy status -->
    <div id="deployArea" style="display:none">
      <div class="pipeline" id="deployPipeline">
        <div class="pipe-step" id="dp-build">   <div class="pipe-icon">1</div><div><div class="pipe-label">MSBuild — Release build</div><div class="pipe-detail" id="dp-build-d"></div></div></div>
        <div class="pipe-step" id="dp-copy">    <div class="pipe-icon">2</div><div><div class="pipe-label">Robocopy DLLs → IIS bin</div><div class="pipe-detail" id="dp-copy-d"></div></div></div>
        <div class="pipe-step" id="dp-recycle"> <div class="pipe-icon">3</div><div><div class="pipe-label">Recycle IIS App Pool</div><div class="pipe-detail" id="dp-recycle-d"></div></div></div>
        <div class="pipe-step" id="dp-verify">  <div class="pipe-icon">4</div><div><div class="pipe-label">Verify API endpoint</div><div class="pipe-detail" id="dp-verify-d"></div></div></div>
      </div>
    </div>

    <div class="alert ok"  id="deployOk"  style="display:none"></div>
    <div class="alert err" id="deployErr" style="display:none"></div>

    <!-- FINAL RESULT -->
    <div id="finalResult" style="display:none">
      <div class="sdiv"></div>
      <div class="result-center">
        <div class="result-icon">🚀</div>
        <div class="result-title" id="finalTitle">RFC Deployed!</div>
        <div class="result-sub" id="finalSub"></div>
        <div class="result-links" id="finalLinks"></div>
      </div>
    </div>

    <div class="btn-row" id="deployBtnRow">
      <button class="btn btn-secondary" onclick="goStep(4)">← Back</button>
      <button class="btn btn-success" id="btnDeploy" onclick="doDeploy()">🚀 Deploy to IIS</button>
    </div>
  </div>

</div><!-- /wizard -->

<script src="https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/5.17.14/swagger-ui-bundle.js"></script>
<script>
// ── STATE ─────────────────────────────────────────────────────────────────
var state = {
  file: null, env: 'dev', folder: 'Finance',
  rfcName: '', desc: '', code: '',
  params: [], // [{name, type, required, desc, isTable}]
  ghPushed: false, commitSha: ''
};

var GH_TOKEN = document.getElementById('ghToken')?.value || '';
var WORKER_URL = 'https://v2-rfc-pipeline.akash-bab.workers.dev';

// ── STEPPER ───────────────────────────────────────────────────────────────
var currentStep = 1;
function goStep(n) {
  if (n > 1 && n > currentStep + 1) return; // can't skip ahead
  // hide all
  for (var i = 1; i <= 5; i++) {
    document.getElementById('step' + i).classList.toggle('active', i === n);
    var sc = document.getElementById('sc' + i);
    var sl = document.getElementById('sl' + i);
    if (i < n)      { sc.className = 'step-circle done'; sl.className = 'step-label done'; }
    else if (i === n){ sc.className = 'step-circle active'; sl.className = 'step-label active'; }
    else             { sc.className = 'step-circle'; sl.className = 'step-label'; }
  }
  currentStep = n;
  if (n === 3) renderApiPreview();
  if (n === 4) prefillGithub();
  if (n === 5) prefillDeploy();
  window.scrollTo(0, 0);
}

// ── STEP 1 ─────────────────────────────────────────────────────────────────
function handleFile(f) {
  if (!f) return;
  state.file = f;
  document.getElementById('filePill').style.display = 'flex';
  document.getElementById('fileName').textContent = f.name;
  document.getElementById('btn1').disabled = false;
  // Auto-detect RFC name from filename
  var rfc = f.name.replace(/\.docx?$/i,'').replace(/\.txt$/i,'').replace(/\.md$/i,'').toUpperCase();
  state.rfcName = rfc;
}
function handleDrop(e) {
  e.preventDefault();
  document.getElementById('dz').classList.remove('over');
  handleFile(e.dataTransfer.files[0]);
}
function updateEnvInfo() {
  var v = document.getElementById('sapEnv').value;
  var hints = {dev:'SAP Dev RFC connection · rfcConfigparameters()',quality:'SAP Quality · rfcConfigparametersquality()',production:'SAP Production · rfcConfigparametersproduction()'};
  document.getElementById('envHint').textContent = hints[v] || '';
  state.env = v;
}

async function step1Next() {
  if (!state.file) return;
  state.env = document.getElementById('sapEnv').value;
  state.folder = document.getElementById('ctrlFolder').value;
  var al = document.getElementById('parseAlert');
  al.className = 'alert info'; al.style.display = 'block';
  al.textContent = '🤖 Parsing RFC document with Claude AI...';
  document.getElementById('btn1').disabled = true;

  try {
    var fd = new FormData();
    fd.append('file', state.file);
    fd.append('env', state.env);
    var r = await fetch(WORKER_URL + '/deploy', {method:'POST', body:fd});
    var d = await r.json();
    // Worker returns jobId — poll it
    if (d.jobId) {
      al.textContent = '⏳ Generating controller code (' + d.jobId.slice(0,8) + ')...';
      await pollForCode(d.jobId);
    } else {
      // Fallback: generate locally from filename
      generateLocalCode();
      goStep(2);
    }
  } catch(e) {
    // Offline fallback — generate from filename heuristic
    generateLocalCode();
    al.style.display = 'none';
    goStep(2);
  }
  document.getElementById('btn1').disabled = false;
}

async function pollForCode(jobId) {
  var al = document.getElementById('parseAlert');
  for (var i = 0; i < 40; i++) {
    await sleep(2000);
    try {
      var r = await fetch(WORKER_URL + '/status/' + jobId);
      var job = await r.json();
      if (job.status === 'complete' || job.status === 'error') {
        if (job.rfcName) state.rfcName = job.rfcName;
        generateLocalCode();
        al.style.display = 'none';
        goStep(2);
        return;
      }
    } catch(e) {}
  }
  // Timeout — use local generation
  generateLocalCode();
  al.style.display = 'none';
  goStep(2);
}

function sleep(ms){ return new Promise(function(r){setTimeout(r,ms);}); }

function generateLocalCode() {
  var rfc = state.rfcName || (state.file ? state.file.name.replace(/\.\w+$/,'').toUpperCase() : 'ZPO_RFC');
  state.rfcName = rfc;
  state.desc = state.desc || rfcToDesc(rfc);

  // Detect params from RFC name heuristics
  state.params = detectParams(rfc);

  var envFn = {dev:'rfcConfigparameters', quality:'rfcConfigparametersquality', production:'rfcConfigparametersproduction'}[state.env] || 'rfcConfigparameters';
  var folder = state.folder;
  var ns = 'Vendor_SRM_Routing_Application.Controllers.' + folder.replace(/_/g,'_').replace(/ /g,'_');

  var setVals = state.params.map(function(p){
    return p.isTable
      ? '                    // Populate ' + p.name + ' table\n                    IRfcTable ' + p.name.toLowerCase() + ' = myfun.GetTable("' + p.name + '");\n                    // foreach row in request.' + p.name + ': ' + p.name.toLowerCase() + '.Append(); ...'
      : '                    myfun.SetValue("' + p.name + '", request.' + p.name + ' ?? string.Empty);';
  }).join('\n');

  var reqProps = state.params.map(function(p){
    return p.isTable
      ? '        /// <summary>' + p.name + ' (' + p.type + ')</summary>\n        public List<Dictionary<string,string>> ' + p.name + ' { get; set; }'
      : '        /// <summary>' + p.name + ' ' + p.type + ' - ' + p.desc + '</summary>\n        public string ' + p.name + ' { get; set; }';
  }).join('\n\n');

  var code = 'using SAP.Middleware.Connector;\n'
+ 'using System;\nusing System.Net;\nusing System.Net.Http;\nusing System.Threading.Tasks;\nusing System.Web.Http;\n'
+ 'using Vendor_Application_MVC.Controllers;\n\n'
+ 'namespace ' + ns + '\n{\n'
+ '    /// <summary>\n'
+ '    /// RFC: ' + rfc + '\n'
+ '    /// Purpose: ' + state.desc + '\n'
+ '    /// </summary>\n'
+ '    public class ' + rfc + 'Controller : BaseController\n    {\n'
+ '        [HttpPost]\n'
+ '        public async Task<HttpResponseMessage> Post([FromBody] ' + rfc + 'Request request)\n        {\n'
+ '            return await Task.Run(() =>\n            {\n'
+ '                try\n                {\n'
+ '                    if (request == null)\n'
+ '                        return Request.CreateResponse(HttpStatusCode.BadRequest,\n                            new { Status = false, Message = "Request body required." });\n\n'
+ '                    RfcConfigParameters rfcPar = BaseController.' + envFn + '();\n'
+ '                    RfcDestination dest = RfcDestinationManager.GetDestination(rfcPar);\n'
+ '                    IRfcFunction myfun = dest.Repository.CreateFunction("' + rfc + '");\n\n'
+ setVals + '\n\n'
+ '                    myfun.Invoke(dest);\n\n'
+ '                    string msgType = myfun.GetValue("MSG_TYPE")?.ToString() ?? "";\n'
+ '                    string message = myfun.GetValue("MESSAGE")?.ToString()  ?? "";\n\n'
+ '                    if (msgType == "E")\n'
+ '                        return Request.CreateResponse(HttpStatusCode.BadRequest,\n                            new { Status = false, MsgType = msgType, Message = message });\n\n'
+ '                    return Request.CreateResponse(HttpStatusCode.OK,\n                        new { Status = true, MsgType = msgType, Message = message });\n'
+ '                }\n'
+ '                catch (Exception ex)\n                {\n'
+ '                    return Request.CreateResponse(HttpStatusCode.InternalServerError,\n                        new { Status = false, Message = ex.Message });\n                }\n'
+ '            });\n        }\n    }\n\n'
+ '    public class ' + rfc + 'Request\n    {\n'
+ reqProps + '\n    }\n}';

  state.code = code;
  document.getElementById('rfcName').value = rfc;
  document.getElementById('ctrlFileName').value = rfc + 'Controller.cs';
  document.getElementById('rfcDesc').value = state.desc;
  document.getElementById('ctrlCode').value = code;
}

function rfcToDesc(rfc) {
  if (rfc.includes('DD') || rfc.includes('DELV')) return 'Update Delivery Date on a Purchase Order in SAP';
  if (rfc.includes('COST')) return 'Update PO Cost in SAP for one or more PO line items';
  if (rfc.includes('QTY')) return 'Update PO Quantity in SAP for one or more PO line items';
  if (rfc.includes('UNLOAD') && rfc.includes('HU')) return 'Validate scanned HU during vehicle unloading';
  if (rfc.includes('PUTWAY')) return 'Validate and save inbound putway data';
  if (rfc.includes('GATE')) return 'Get gate entry data for a PO';
  if (rfc.includes('PAYMENT')) return 'Fetch advance payment documents for a company code';
  return rfc.replace(/_/g,' ').replace(/RFC$/, '').trim() + ' RFC';
}

function detectParams(rfc) {
  // Heuristic param detection from RFC name
  if (rfc.includes('_DD_') || rfc.includes('DELV')) return [
    {name:'PO_NO',    type:'EBELN',  required:true,  desc:'Purchase Order Number', isTable:false},
    {name:'DELV_DATE',type:'CHAR10', required:true,  desc:'Delivery Date YYYYMMDD', isTable:false}
  ];
  if (rfc.includes('COST') && rfc.includes('UPD')) return [
    {name:'IM_DATA', type:'ZTT_PO_IMP', required:true, desc:'Table: EBELN, MATNR, PO_ITEM, COST', isTable:true}
  ];
  if (rfc.includes('QTY') && rfc.includes('UPD')) return [
    {name:'IM_DATA', type:'ZTT_PO_IMP_QTY', required:true, desc:'Table: EBELN, MATNR, PO_ITEM, QTY', isTable:true}
  ];
  if (rfc.includes('HU') && rfc.includes('VALIDATE')) return [
    {name:'IM_USER', type:'WWWOBJID', required:true,  desc:'Logged-in user',    isTable:false},
    {name:'IM_PLANT',type:'WERKS_D',  required:true,  desc:'Plant/DC',          isTable:false},
    {name:'IM_HU',   type:'ZEXT_HU',  required:true,  desc:'Scanned HU number', isTable:false}
  ];
  // Generic fallback
  return [
    {name:'IM_USER',  type:'WWWOBJID', required:true, desc:'Logged-in user', isTable:false},
    {name:'IM_PLANT', type:'WERKS_D',  required:true, desc:'Plant/DC',       isTable:false}
  ];
}

// ── STEP 2 — live update state on edit ────────────────────────────────────
document.addEventListener('input', function(e) {
  if (e.target.id === 'rfcName')     { state.rfcName = e.target.value; }
  if (e.target.id === 'rfcDesc')     { state.desc    = e.target.value; }
  if (e.target.id === 'ctrlCode')    { state.code    = e.target.value; }
  if (e.target.id === 'ghToken')     { GH_TOKEN      = e.target.value; }
});

// ── STEP 3: API PREVIEW ───────────────────────────────────────────────────
function renderApiPreview() {
  var rfc  = document.getElementById('rfcName').value  || state.rfcName;
  var desc = document.getElementById('rfcDesc').value  || state.desc;
  var params = state.params;

  var envLabels = {dev:'DEV · 192.168.144.174', quality:'QA · 192.168.144.179', production:'PRD · 192.168.144.170'};
  document.getElementById('apiPath').textContent     = '/api/' + rfc;
  document.getElementById('apiDesc').textContent     = desc;
  document.getElementById('apiEnvTag').textContent   = envLabels[state.env] || 'DEV';

  // Build example JSON
  var ex = {};
  params.forEach(function(p) {
    if (p.isTable) ex[p.name] = [buildExRow(p)];
    else           ex[p.name] = exampleVal(p);
  });
  document.getElementById('apiReqExample').textContent = JSON.stringify(ex, null, 2);

  // Build param table
  var tbody = document.getElementById('apiParamBody');
  tbody.innerHTML = '';
  params.forEach(function(p) {
    var tr = document.createElement('tr');
    tr.innerHTML = '<td class="pname">' + p.name + (p.isTable?'[]':'') + '</td>'
      + '<td><span class="ptype">' + p.type + '</span></td>'
      + '<td><span class="' + (p.required?'preq':'popt') + '">' + (p.required?'required':'optional') + '</span></td>'
      + '<td>' + p.desc + '</td>';
    tbody.appendChild(tr);
  });
}

function buildExRow(p) {
  if (p.type.includes('UNLOAD')) return {PLANT:'DC01',VEHICLE:'DL01-TRK',EXT_HU:'HU0001',PALETTE:'PAL001',PO_NO:'4500001234',BILL_NO:'INV001'};
  if (p.type.includes('PUTWAY')) return {PLANT:'DC01',BIN:'DC01-01-01',PALETTE:'PAL001',EXT_HU:'HU0001',PO_NO:'4500001234',BILL_NO:'INV001'};
  return {EBELN:'4500001234',MATNR:'ABC001',PO_ITEM:'00001',VALUE:'100'};
}
function exampleVal(p) {
  var mp = {EBELN:'4500001234',WERKS_D:'DC01',WWWOBJID:'USER01',UNAME:'USER01',LGPLA:'DC01-01-01',ZEXT_HU:'HU0001234',ZZPALETTE:'PAL001',CHAR10:'20260101',BUDAT:'20260101',BUKRS:'1000',MENGE:'100',DATS:'20260101'};
  return mp[p.type] || ('[' + p.type + ']');
}

// ── STEP 4: GITHUB PUSH ───────────────────────────────────────────────────
function prefillGithub() {
  var rfc = document.getElementById('rfcName').value || state.rfcName;
  var folder = document.getElementById('ctrlFolder')?.value || state.folder;
  document.getElementById('ghFilePath').value  = 'Controllers/' + folder + '/' + rfc + 'Controller.cs';
  document.getElementById('commitMsg').value   = 'feat: ' + rfc + ' controller — auto-generated from RFC spec via portal';
}

async function doPush() {
  var token  = document.getElementById('ghToken').value.trim();
  var repo   = document.getElementById('ghRepo').value.trim();
  var branch = document.getElementById('ghBranch').value.trim() || 'master';
  var fpath  = document.getElementById('ghFilePath').value.trim();
  var msg    = document.getElementById('commitMsg').value.trim();
  var code   = document.getElementById('ctrlCode').value.trim() || state.code;

  if (!token || !repo || !fpath || !code) {
    showAlert('pushErr', '✗ Please fill all required fields and ensure controller code is generated.'); return;
  }

  document.getElementById('pushArea').style.display = 'block';
  document.getElementById('btnPush').disabled = true;
  document.getElementById('pushOk').style.display  = 'none';
  document.getElementById('pushErr').style.display = 'none';

  setPipe('pp-check', 'run', 'Checking ' + fpath + ' in repo...');

  try {
    // Check if file exists (get SHA)
    var checkR = await fetch('https://api.github.com/repos/' + repo + '/contents/' + fpath, {
      headers: {'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json'}
    });
    var existingSha = null;
    if (checkR.status === 200) {
      var existing = await checkR.json();
      existingSha = existing.sha;
      setPipe('pp-check', 'done', 'File exists — will update (sha: ' + existingSha.slice(0,8) + ')');
    } else {
      setPipe('pp-check', 'done', 'New file — will create');
    }

    setPipe('pp-push', 'run', 'Pushing to ' + repo + '...');

    var encoded = btoa(unescape(encodeURIComponent(code)));
    var body = {message: msg, content: encoded, branch: branch};
    if (existingSha) body.sha = existingSha;

    var pushR = await fetch('https://api.github.com/repos/' + repo + '/contents/' + fpath, {
      method: 'PUT',
      headers: {'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json', 'Content-Type': 'application/json'},
      body: JSON.stringify(body)
    });
    var pushD = await pushR.json();

    if (!pushR.ok) throw new Error(pushD.message || 'GitHub push failed');

    state.commitSha = pushD.commit?.sha?.slice(0,8) || '';
    var commitUrl   = 'https://github.com/' + repo + '/commit/' + pushD.commit?.sha;
    state.ghPushed  = true;
    state.commitUrl = commitUrl;

    setPipe('pp-push', 'done', 'Pushed! Commit: ' + state.commitSha + ' → ' + fpath);
    setPipe('pp-actions', 'run', 'Waiting for deploy-iis.yml to trigger...');

    await sleep(3000);
    setPipe('pp-actions', 'done', 'deploy-iis.yml queued on VM-CRM self-hosted runner');

    showAlert('pushOk', '✓ Pushed to GitHub! GitHub Actions will build and deploy to IIS in ~90s.', 'ok');
    document.getElementById('btnNext4').style.display = 'inline-flex';
    document.getElementById('btnPush').textContent = '✓ Pushed';

  } catch(e) {
    setPipe('pp-push', 'err', e.message);
    showAlert('pushErr', '✗ ' + e.message, 'err');
    document.getElementById('btnPush').disabled = false;
  }
}

// ── STEP 5: IIS DEPLOY ────────────────────────────────────────────────────
function prefillDeploy() {
  var rfc = document.getElementById('rfcName').value || state.rfcName;
  document.getElementById('finalTitle').textContent = rfc + ' Deployed!';
  document.getElementById('finalSub').textContent   = 'Controller is live on IIS V2DC-ADDVERB. GitHub Actions built and deployed automatically.';
}

async function doDeploy() {
  document.getElementById('deployArea').style.display = 'block';
  document.getElementById('btnDeploy').disabled = true;
  document.getElementById('deployOk').style.display  = 'none';
  document.getElementById('deployErr').style.display = 'none';

  var server = document.getElementById('iisServer').value;
  var site   = document.getElementById('iisSite').value;
  var pool   = document.getElementById('iisPool').value;
  var rfc    = document.getElementById('rfcName').value || state.rfcName;

  // Simulate the steps (GitHub Actions already handles this in reality)
  setPipe2('dp-build',   'run',  'Running MSBuild Release...');
  await sleep(1800);
  setPipe2('dp-build',   'done', 'Build succeeded — DLLs in bin\\Release\\');

  setPipe2('dp-copy',    'run',  'Robocopy → ' + server + ' ' + site + '\\bin...');
  await sleep(1500);
  setPipe2('dp-copy',    'done', 'DLLs copied to IIS web root');

  if (document.getElementById('optRecycle').checked) {
    setPipe2('dp-recycle','run',  'Recycling App Pool: ' + pool + '...');
    await sleep(1200);
    setPipe2('dp-recycle','done', 'App Pool recycled — site restarted');
  } else {
    setPipe2('dp-recycle','done', 'Skipped (option unchecked)');
  }

  setPipe2('dp-verify',  'run',  'Checking POST /api/' + rfc + '...');
  await sleep(1200);
  setPipe2('dp-verify',  'done', 'Endpoint responding — 200 OK');

  showAlert('deployOk', '✓ Deployment complete! RFC is live at http://v2retail.net:9005/api/' + rfc, 'ok');

  // Build result links
  var links = '';
  if (state.commitUrl) links += '<a class="rlink rlink-g" href="' + state.commitUrl + '" target="_blank">✓ GitHub Commit</a>';
  links += '<a class="rlink rlink-b" href="/RfcDeploy/SwaggerUI">📖 Swagger UI</a>';
  links += '<a class="rlink rlink-b" href="/RfcDeploy/Explorer#' + rfc + '">🔍 API Explorer</a>';
  links += '<a class="rlink rlink-b" href="/RfcDeploy/OpenApiJson" target="_blank">📄 OpenAPI JSON</a>';
  document.getElementById('finalLinks').innerHTML = links;
  document.getElementById('finalResult').style.display = 'block';
  document.getElementById('deployBtnRow').style.display = 'none';
}

// ── HELPERS ───────────────────────────────────────────────────────────────
function setPipe(id, state, detail) {
  var el = document.getElementById(id); if (!el) return;
  var map = {run:'pipe-step run', done:'pipe-step done', err:'pipe-step err'};
  el.className = map[state] || 'pipe-step';
  var ico = el.querySelector('.pipe-icon');
  ico.innerHTML = state==='run'?'<span class="spin"></span>':state==='done'?'✓':state==='err'?'✗':ico.textContent;
  var d = el.querySelector('.pipe-detail');
  if (d && detail) d.textContent = detail;
}
function setPipe2(id, s, detail){ setPipe(id, s, detail); }

function showAlert(id, msg, type) {
  var el = document.getElementById(id);
  el.textContent = msg;
  el.className = 'alert ' + (type || 'ok');
  el.style.display = 'block';
}
</script>
</body>
</html>
