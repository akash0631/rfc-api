<script src="https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/5.17.14/swagger-ui-bundle.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/5.17.14/swagger-ui-standalone-preset.js"></script>
<script>
var WORKER = '@Html.Raw(workerBase)';
var selFile = null, selEnvV = 'dev', poll = null, swInit = false;

function showPanel(n) {
  var ps = ['upload','swagger','iis'];
  var lb = {upload:'Deploy RFC',swagger:'Swagger UI',iis:'IIS Config'};
  ps.forEach(function(p){
    var el = document.getElementById('panel-'+p);
    if(el) el.style.display = p===n ? (p==='swagger' ? 'block' : 'block') : 'none';
  });
  ps.forEach(function(p){ var ni = document.getElementById('nav-'+p); if(ni) ni.classList.toggle('active',p===n); });
  var nb = document.getElementById('nav-explorer'); if(nb) nb.classList.remove('active');
  document.getElementById('tbc').textContent = lb[n]||n;
  if(n==='swagger') initSwagger();
}
function openExplorer(){ window.location.href='/RfcDeploy/Explorer'; }

function handleFile(f){ if(!f)return; selFile=f; document.getElementById('fp').style.display='flex'; document.getElementById('fn2').textContent=f.name; document.getElementById('deployBtn').disabled=false; }
function handleDrop(e){ e.preventDefault(); document.getElementById('drop').classList.remove('over'); handleFile(e.dataTransfer.files[0]); }
function selEnv(e){ selEnvV=e; ['dev','quality','production'].forEach(function(v){ document.getElementById('env-'+v).classList.toggle('active',v===e); }); }

async function deploy(){
  if(!selFile) return;
  document.getElementById('errBox').style.display='none';
  document.getElementById('uploadForm').style.display='none';
  document.getElementById('progressSection').style.display='block';
  var fd=new FormData(); fd.append('file',selFile); fd.append('env',selEnvV);
  try{
    var r=await fetch(WORKER+'/deploy',{method:'POST',body:fd});
    var d=await r.json();
    if(!r.ok) throw new Error(d.error||'Deploy failed');
    pollJob(d.jobId);
  }catch(e){
    document.getElementById('progressSection').style.display='none';
    document.getElementById('uploadForm').style.display='block';
    var eb=document.getElementById('errBox');
    eb.textContent='✗ '+e.message; eb.className='alert err'; eb.style.display='block';
  }
}
var SICO={running:'<span class="spin"></span>',done:'✓',error:'✗'};
function upStep(id,st,det){
  var el=document.getElementById('s-'+id); if(!el) return;
  el.className='step '+({running:'run',done:'done',error:'err'}[st]||'');
  el.querySelector('.si').innerHTML=SICO[st]||el.querySelector('.si').innerHTML;
  if(det){ var d=el.querySelector('.sd'); if(!d){d=document.createElement('div');d.className='sd';el.querySelector(':last-child').appendChild(d);} d.textContent=det; }
}
function pollJob(jid){
  poll=setInterval(async function(){
    try{
      var r=await fetch(WORKER+'/status/'+jid); var job=await r.json();
      (job.steps||[]).forEach(function(s){upStep(s.step,s.status,s.detail);});
      if(job.status==='complete'){clearInterval(poll);showResult(job);}
      else if(job.status==='error'){
        clearInterval(poll);
        document.getElementById('progressSection').style.display='none';
        document.getElementById('uploadForm').style.display='block';
        var eb=document.getElementById('errBox');
        eb.textContent='✗ '+(job.error||'Pipeline error'); eb.className='alert err'; eb.style.display='block';
      }
    }catch(e){}
  },1500);
}
function showResult(job){
  document.getElementById('progressSection').style.display='none';
  document.getElementById('resultSection').style.display='block';
  document.getElementById('rtitle').textContent=(job.rfcName||'RFC')+' Deployed!';
  var ep=document.getElementById('epDisp');
  ep.innerHTML='<span class="ep-lbl">RFC REST API · IIS (v2retail.net:9005)</span>POST /api/'+(job.rfcName||'RFC_NAME')+(job.dataLake?'\n<span class="ep-lbl" style="margin-top:8px">Data Lake · Azure DAB</span>'+job.dataLake+'?$top=100':'');
  var c=document.getElementById('chips'); c.innerHTML='';
  if(job.commit)   c.innerHTML+='<a class="chip cg" href="'+job.commit+'" target="_blank">✓ GitHub Commit</a>';
  if(job.dataLake) c.innerHTML+='<a class="chip cb" href="'+job.dataLake+'" target="_blank">📡 Data Lake</a>';
  c.innerHTML+='<a class="chip cb" href="/RfcDeploy/SwaggerUI">📖 Swagger UI</a>';
  c.innerHTML+='<a class="chip cp" href="https://github.com/akash0631/rfc-api/actions" target="_blank">⚙ Actions</a>';
}
function resetDeploy(){
  selFile=null; if(poll)clearInterval(poll);
  document.getElementById('resultSection').style.display='none';
  document.getElementById('progressSection').style.display='none';
  document.getElementById('uploadForm').style.display='block';
  document.getElementById('fp').style.display='none';
  document.getElementById('errBox').style.display='none';
  document.getElementById('deployBtn').disabled=true;
  selEnv('dev');
  ['parse','controller','github','dab','swagger'].forEach(function(id){
    var el=document.getElementById('s-'+id); if(!el) return;
    el.className='step';
    var nums={parse:'1',controller:'2',github:'3',dab:'4',swagger:'5'};
    el.querySelector('.si').innerHTML=nums[id];
    var d=el.querySelector('.sd'); if(d) d.remove();
  });
}

function initSwagger(){
  if(swInit) return; swInit=true;
  SwaggerUIBundle({
    url:'/RfcDeploy/OpenApiJson',
    dom_id:'#swagger-ui-mount',
    deepLinking:true,
    presets:[SwaggerUIBundle.presets.apis,SwaggerUIStandalonePreset],
    layout:'StandaloneLayout',
    docExpansion:'list',
    defaultModelsExpandDepth:-1,
    tryItOutEnabled:true,
    filter:true,
    requestInterceptor:function(req){
      if(req.url&&req.url.startsWith('http://v2retail.net:9005'))
        req.url=req.url.replace('http://v2retail.net:9005',window.location.origin);
      return req;
    }
  });
}

function sit(n){
  var ts=['sap','deploy','github','dab','worker'];
  ts.forEach(function(t){ document.getElementById('it-'+t).style.display=t===n?'block':'none'; });
  document.querySelectorAll('.itab').forEach(function(el,i){ el.classList.toggle('active',ts[i]===n); });
}

function showAlert(id,msg,type){ var el=document.getElementById(id); el.textContent=msg; el.className='alert '+type; el.style.display='block'; setTimeout(function(){el.style.display='none';},5000); }
function save(k){ showAlert('al-'+k,'✓ Config saved — takes effect on next IIS recycle or app restart','ok'); }

async function testSap(){
  showAlert('al-sap','🔄 Testing SAP RFC connection...','info');
  try{
    var r=await fetch('/api/ZTEST_RFC',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({IM_USER:'TEST'})});
    showAlert('al-sap',r.ok?'✓ SAP connection successful — RFC callable':'⚠ SAP reachable but check credentials','ok');
  }catch(e){ showAlert('al-sap','✗ SAP connection failed: '+e.message,'err'); }
}
async function testGh(){
  showAlert('al-github','🔄 Testing GitHub API...','info');
  try{
    var r=await fetch('https://api.github.com/repos/akash0631/rfc-api',{headers:{'Accept':'application/vnd.github.v3+json'}});
    var d=await r.json();
    if(d.id) showAlert('al-github','✓ GitHub accessible · '+d.full_name+' · '+d.default_branch+' branch','ok');
    else      showAlert('al-github','✗ GitHub: '+(d.message||'error'),'err');
  }catch(e){ showAlert('al-github','✗ '+e.message,'err'); }
}
async function testWorker(){
  showAlert('al-worker','🔄 Pinging Cloudflare Worker...','info');
  try{
    var r=await fetch(document.getElementById('w-url').value+'/status/ping');
    showAlert('al-worker',(r.ok||r.status===404)?'✓ Worker reachable (HTTP '+r.status+')':'✗ Worker HTTP '+r.status,(r.ok||r.status===404)?'ok':'err');
  }catch(e){ showAlert('al-worker','✗ '+e.message,'err'); }
}
async function triggerDeploy(){
  showAlert('al-deploy','🔄 Triggering GitHub Actions deploy...','info');
  try{
    var r=await fetch('https://api.github.com/repos/akash0631/rfc-api/actions/workflows/deploy-iis.yml/dispatches',{
      method:'POST',headers:{'Accept':'application/vnd.github.v3+json','Content-Type':'application/json'},
      body:JSON.stringify({ref:'master',inputs:{rfc_name:'manual'}})
    });
    showAlert('al-deploy',r.status===204?'✓ Deploy triggered! Check GitHub Actions.':'⚠ HTTP '+r.status+' — open Actions manually','ok');
  }catch(e){ showAlert('al-deploy','✗ '+e.message,'err'); }
}
</script>
</body>
</html>
